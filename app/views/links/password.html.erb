<div class="min-h-screen flex items-center justify-center bg-gray-100 px-4">

  <div class="bg-white shadow-xl rounded-2xl w-full max-w-md p-8">

    <!-- Header -->
    <h2 class="text-2xl font-bold text-gray-800 mb-4 text-center">🔒 Enter Password</h2>
    <p class="text-gray-500 text-center mb-6">
      This link is password protected. Please enter the password to continue.
    </p>

    <!-- Form -->
    <%= form_with url: unlock_path, method: :post, local: true, data: { turbo: false } do |f| %>
      
      <%= hidden_field_tag :short_code, @link.short_code %>

      <div class="mb-4">
        <%= f.password_field :password, placeholder: "Enter password",
            class: "w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <% if flash[:alert] %>
        <p class="text-red-600 text-sm mb-3"><%= flash[:alert] %></p>
      <% end %>

      <div class="flex justify-center">
        <%= f.submit "Unlock",
            class: "bg-gradient-to-r from-blue-600 to-indigo-600 text-white px-6 py-3 rounded-xl shadow hover:opacity-90 w-full" %>
      </div>

    <% end %>

    <!-- Optional footer -->
    <p class="text-gray-400 text-xs mt-4 text-center">
      <%= link_to "Back to Dashboard", links_path, class: "hover:underline" %>
    </p>

  </div>

</div>
