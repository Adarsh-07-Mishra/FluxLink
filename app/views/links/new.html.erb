<div class="min-h-screen bg-slate-50 px-4 py-12">
  <div class="mx-auto max-w-6xl grid gap-10 lg:grid-cols-[1.1fr_.9fr]">
    <div class="rounded-[32px] bg-gradient-to-br from-sky-600 to-indigo-700 p-10 text-white shadow-2xl">
      <div class="space-y-6">
        <span class="inline-flex rounded-full bg-white/15 px-3 py-1 text-xs font-semibold uppercase tracking-[.24em] text-slate-100">Modern shortening</span>
        <div>
          <h1 class="text-4xl font-semibold tracking-tight">Create a short URL in seconds</h1>
          <p class="mt-4 text-sm leading-6 text-slate-200 max-w-xl">Just paste your destination URL and pick the settings you need. Smart defaults keep the experience fast and simple.</p>
        </div>
        <div class="grid gap-4">
          <div class="rounded-[28px] bg-white/10 p-5">
            <p class="font-semibold text-slate-100">Fast setup</p>
            <p class="mt-2 text-sm text-slate-300">No extra steps — only the fields that matter.</p>
          </div>
          <div class="rounded-[28px] bg-white/10 p-5">
            <p class="font-semibold text-slate-100">Built for sharing</p>
            <p class="mt-2 text-sm text-slate-300">Optional password and QR code support for private distribution.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="rounded-[32px] bg-white p-10 shadow-2xl ring-1 ring-slate-200">
      <div class="mb-8">
        <h2 class="text-3xl font-semibold text-slate-900">Shorten your link</h2>
        <p class="mt-2 text-sm text-slate-500">Minimal form, powerful outcome.</p>
      </div>

      <% if @link.errors.any? %>
        <div class="rounded-3xl border border-red-200 bg-red-50 p-4 mb-6 text-sm text-red-700">
          <ul class="list-disc pl-5 space-y-1">
            <% @link.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @link, data: { turbo: false }, class: "space-y-6" do |f| %>
        <div>
          <%= f.label :original_url, "Paste your URL", class: "block text-sm font-semibold text-slate-700 mb-3" %>
          <div class="relative">
            <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400">https://</span>
            <%= f.url_field :original_url,
                class: "w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 pl-24 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20",
                placeholder: "example.com/page" %>
          </div>
        </div>

        <div class="grid gap-5 lg:grid-cols-2">
          <div>
            <%= f.label :short_code, "Custom alias", class: "block text-sm font-semibold text-slate-700 mb-3" %>
            <div class="rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 shadow-sm">
              <%= f.text_field :short_code, class: "w-full bg-transparent text-sm text-slate-900 focus:outline-none", placeholder: "optional" %>
            </div>
          </div>

          <div>
            <%= f.label :expires_at, "Expires at", class: "block text-sm font-semibold text-slate-700 mb-3" %>
            <div class="rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 shadow-sm">
              <%= f.datetime_local_field :expires_at,
                  value: (@link.expires_at&.strftime("%Y-%m-%dT%H:%M")),
                  class: "w-full bg-transparent text-sm text-slate-900 focus:outline-none",
                  placeholder: "Optional" %>
            </div>
          </div>
        </div>

        <div>
          <%= f.label :password, "Password lock", class: "block text-sm font-semibold text-slate-700 mb-3" %>
          <div class="rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 shadow-sm">
            <%= f.password_field :password,
                class: "w-full bg-transparent text-sm text-slate-900 focus:outline-none",
                placeholder: "optional" %>
          </div>
        </div>

        <div class="rounded-[28px] border border-slate-200 bg-slate-50 p-4 flex items-center justify-between gap-4">
          <div>
            <p class="text-sm font-semibold text-slate-900">Generate QR code</p>
            <p class="text-sm text-slate-500">Instantly create a scannable link.</p>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <%= f.check_box :generate_qr, { class: "sr-only peer" }, true, false %>
            <span class="w-14 h-7 rounded-full bg-slate-300 peer-checked:bg-sky-500 transition-all duration-200"></span>
            <span class="absolute left-1 top-1 h-5 w-5 rounded-full bg-white shadow transform transition peer-checked:translate-x-7"></span>
          </label>
        </div>

        <div>
          <%= f.submit "Create Short Link",
              class: "w-full rounded-3xl bg-gradient-to-r from-sky-600 to-indigo-600 py-4 text-sm font-semibold text-white shadow-xl shadow-sky-500/20 transition hover:scale-[1.01] hover:from-sky-700 hover:to-indigo-700" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
