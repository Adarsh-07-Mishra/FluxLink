<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-purple-100 p-6 lg:p-8">
  <div class="mx-auto max-w-7xl">

    <!-- ================= HEADER ================= -->
    <div class="mb-8">
      <p class="text-sm uppercase tracking-widest text-blue-500 font-semibold">Link Details</p>
      <h1 class="text-5xl font-bold text-slate-900 mt-2">Manage Your Link</h1>
      <p class="text-slate-500 mt-2 text-lg">Monitor performance, share securely, and track every click</p>
    </div>

    <!-- ================= MAIN CONTENT ================= -->
    <div class="grid gap-8 lg:grid-cols-[1.3fr_.7fr] mb-8">

      <!-- LEFT SECTION -->
      <div class="space-y-6">

        <!-- Short URL Card -->
        <div class="bg-white/80 backdrop-blur-xl rounded-3xl p-8 shadow-xl border border-white/20 hover:shadow-2xl transition duration-300">
          <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-4">Your Short URL</p>
          
          <div class="space-y-4">
            <div class="bg-gradient-to-r from-blue-50 to-purple-50 rounded-2xl p-6 border border-blue-100/50">
              <p class="text-sm text-slate-600 mb-2">Short Link</p>
              <p class="font-mono text-xl font-bold text-blue-600 break-all"><%= short_url(@link.short_code) %></p>
            </div>

            <div class="flex gap-3">
              <button id="copy-btn" class="flex-1 bg-gradient-to-r from-blue-600 to-blue-700 text-white px-6 py-3 rounded-xl font-semibold hover:shadow-lg hover:from-blue-700 hover:to-blue-800 transition duration-200 flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                Copy Link
              </button>

              <a href="<%= short_url(@link.short_code) %>" target="_blank" class="flex-1 border-2 border-slate-300 text-slate-900 px-6 py-3 rounded-xl font-semibold hover:border-blue-500 hover:bg-blue-50 transition duration-200 flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Open Link
              </a>
            </div>
          </div>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white/80 backdrop-blur-xl rounded-2xl p-6 shadow-lg border border-white/20 hover:shadow-xl transition duration-300">
            <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-3">Total Clicks</p>
            <p class="text-4xl font-bold bg-gradient-to-r from-green-600 to-emerald-600 bg-clip-text text-transparent"><%= @link.clicks %></p>
          </div>

          <div class="bg-white/80 backdrop-blur-xl rounded-2xl p-6 shadow-lg border border-white/20 hover:shadow-xl transition duration-300">
            <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-3">Status</p>
            <% if !@link.active %>
              <span class="inline-block bg-red-100 text-red-700 px-3 py-1 rounded-full text-sm font-semibold">Inactive</span>
            <% elsif @link.expired? %>
              <span class="inline-block bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-sm font-semibold">Expired</span>
            <% else %>
              <span class="inline-block bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-semibold">Active</span>
            <% end %>
          </div>
        </div>

      </div>

      <!-- RIGHT SECTION -->
      <div class="bg-white/80 backdrop-blur-xl rounded-3xl p-8 shadow-xl border border-white/20">
        <div class="space-y-6">

          <!-- Original URL -->
          <div>
            <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-3">Original URL</p>
            <a href="<%= @link.original_url %>" 
              target="_blank" 
              rel="noopener noreferrer"
              class="block text-blue-600 hover:text-blue-800 text-sm leading-6 break-words font-medium hover:underline transition">
              <%= @link.original_url %>
            </a>
          </div>

          <!-- Info Grid -->
          <div class="grid gap-3">

            <!-- Short Code -->
            <div class="bg-gradient-to-br from-slate-50 to-slate-100 rounded-2xl p-5 border border-slate-200/50">
              <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-2">Short Code</p>
              <p class="text-base font-bold text-slate-900 font-mono"><%= @link.short_code %></p>
            </div>

            <!-- Created Date -->
            <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl p-5 border border-blue-200/50">
              <p class="text-xs uppercase tracking-widest text-blue-600 font-semibold mb-2">Created</p>
              <p class="text-base font-bold text-blue-900"><%= @link.created_at.strftime("%d %b %Y, %I:%M %p") %></p>
            </div>

            <!-- Expiry -->
            <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-2xl p-5 border border-purple-200/50">
              <p class="text-xs uppercase tracking-widest text-purple-600 font-semibold mb-2">Expires</p>
              <p class="text-base font-bold text-purple-900">
                <% if @link.expires_at.present? %>
                  <%= @link.expires_at.strftime("%d %b %Y, %I:%M %p") %>
                <% else %>
                  <span class="text-green-600">Never</span>
                <% end %>
              </p>
            </div>

            <!-- QR Status -->
            <div class="bg-gradient-to-br from-emerald-50 to-emerald-100 rounded-2xl p-5 border border-emerald-200/50">
              <p class="text-xs uppercase tracking-widest text-emerald-600 font-semibold mb-2">QR Code</p>
              <p class="text-base font-bold text-emerald-900">
                <% if @link.qr_code_data.present? %>
                  <span class="inline-block bg-emerald-200 text-emerald-700 px-2 py-1 rounded text-xs">✓ Enabled</span>
                <% else %>
                  <span class="inline-block bg-gray-200 text-gray-700 px-2 py-1 rounded text-xs">✗ Disabled</span>
                <% end %>
              </p>
            </div>

          </div>

        </div>
      </div>

    </div>

    <!-- ================= QR SECTION ================= -->
    <% if @link.qr_code_data.present? %>
      <div class="mb-8">
        <div class="bg-white/80 backdrop-blur-xl rounded-3xl p-8 shadow-xl border border-white/20 max-w-md mx-auto">
          <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-4 text-center">QR Code</p>
          
          <div class="bg-slate-50 rounded-2xl p-6 flex justify-center mb-6 border border-slate-200">
            <div id="qr-code">
              <%= raw @link.qr_code_data %>
            </div>
          </div>

          <button id="download-btn" class="w-full bg-gradient-to-r from-green-600 to-emerald-600 text-white px-6 py-3 rounded-xl font-semibold hover:shadow-lg hover:from-green-700 hover:to-emerald-700 transition duration-200 flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download QR Code
          </button>
        </div>
      </div>
    <% end %>

    <!-- ================= CHART SECTION ================= -->
    <div class="mb-8">
      <div class="bg-white/80 backdrop-blur-xl rounded-3xl p-8 shadow-xl border border-white/20">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h3 class="text-2xl font-bold text-slate-900">📊 Click Analytics</h3>
            <p class="text-slate-500 text-sm mt-1">Track clicks over time</p>
          </div>
        </div>
        
        <div class="bg-gradient-to-br from-slate-50 to-slate-100 rounded-2xl p-6">
          <canvas id="clicks-chart" class="w-full" style="max-height: 400px;"></canvas>
        </div>
      </div>
    </div>

    <!-- ================= FOOTER ACTIONS ================= -->
    <div class="flex justify-between items-center gap-4 flex-wrap">
      <%= link_to "← Back to Dashboard", links_path, class: "text-slate-600 hover:text-slate-900 font-semibold transition flex items-center gap-2" %>

      <div class="flex gap-3">
        <%= link_to "Edit Link", link_path(@link), class: "border-2 border-slate-300 text-slate-900 px-6 py-2 rounded-xl font-semibold hover:border-blue-500 hover:bg-blue-50 transition duration-200" %>

        <%= link_to "+ New Link", new_link_path, class: "bg-gradient-to-r from-blue-600 to-purple-600 text-white px-6 py-2 rounded-xl font-semibold hover:shadow-lg hover:from-blue-700 hover:to-purple-700 transition duration-200" %>
      </div>
    </div>

  </div>
</div>

<!-- ================= SCRIPT ================= -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
document.addEventListener("turbo:load", function () {

  // COPY
  const copyBtn = document.getElementById("copy-btn");
  if (copyBtn) {
    copyBtn.addEventListener("click", function () {
      const text = "<%= short_url(@link.short_code) %>";
      navigator.clipboard.writeText(text).then(() => {
        showToast("✓ Copied to clipboard!", "success");
      }).catch(() => {
        showToast("✗ Failed to copy", "error");
      });
    });
  }

  // DOWNLOAD QR
  const downloadBtn = document.getElementById("download-btn");
  if (downloadBtn) {
    downloadBtn.addEventListener("click", function () {
      const svg = document.querySelector("#qr-code svg");
      if (!svg) {
        showToast("✗ QR Code not found", "error");
        return;
      }

      const serializer = new XMLSerializer();
      const source = serializer.serializeToString(svg);
      const blob = new Blob([source], { type: "image/svg+xml" });
      const url = URL.createObjectURL(blob);

      const a = document.createElement("a");
      a.href = url;
      a.download = "qr-<%= @link.short_code %>.svg";
      a.click();

      URL.revokeObjectURL(url);
      showToast("✓ QR Code downloaded!", "success");
    });
  }

  // CHART
  const ctx = document.getElementById("clicks-chart");
  if (ctx) {
    new Chart(ctx, {
      type: 'line',
      data: {
        labels: <%= raw @clicks_chart_labels.to_json %>,
        datasets: [{
          label: 'Clicks',
          data: <%= raw @clicks_chart_data.to_json %>,
          borderColor: '#0ea5e9',
          backgroundColor: 'rgba(14, 165, 233, 0.1)',
          fill: true,
          tension: 0.4,
          borderWidth: 3,
          pointRadius: 6,
          pointBackgroundColor: '#0ea5e9',
          pointBorderColor: '#fff',
          pointBorderWidth: 2,
          pointHoverRadius: 8
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { display: false },
          filler: { propagate: true }
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { color: '#64748b' }
          },
          y: {
            beginAtZero: true,
            ticks: { color: '#64748b' }
          }
        }
      }
    });
  }

  // TOAST NOTIFICATIONS
  function showToast(msg, type = "info") {
    const t = document.createElement("div");
    t.innerText = msg;
    
    const bgColor = type === "success" ? "bg-green-500" : type === "error" ? "bg-red-500" : "bg-blue-500";
    t.className = `fixed bottom-6 right-6 ${bgColor} text-white px-5 py-3 rounded-xl font-semibold shadow-lg animate-fadeIn z-50`;
    
    document.body.appendChild(t);
    
    setTimeout(() => {
      t.style.animation = "fadeOut 0.3s ease-out";
      setTimeout(() => t.remove(), 300);
    }, 2500);
  }
});

// CSS Animations
const style = document.createElement("style");
style.textContent = `
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(20px);
    }
  }
`;
document.head.appendChild(style);
</script>