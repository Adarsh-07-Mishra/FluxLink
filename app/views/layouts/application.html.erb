<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "FluxLink - Smart URL Shortening" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="description" content="Create, protect, and track short links with FluxLink. Fast, secure, and simple URL shortening.">
    <meta name="theme-color" content="#0f172a">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap');

      * {
        font-family: 'Sora', 'Inter', sans-serif;
        @apply transition-all duration-300;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        @apply bg-slate-950;
        background: linear-gradient(135deg, #0f172a 0%, #1a1f35 50%, #0f172a 100%);
        background-attachment: fixed;
        position: relative;
        overflow-x: hidden;
      }

      /* Animated Background Elements */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background: 
          radial-gradient(circle at 20% 50%, rgba(59, 130, 246, 0.2) 0%, transparent 50%),
          radial-gradient(circle at 80% 80%, rgba(168, 85, 247, 0.2) 0%, transparent 50%),
          radial-gradient(circle at 40% 0%, rgba(34, 197, 94, 0.15) 0%, transparent 50%);
        animation: gradientShift 20s ease-in-out infinite;
        pointer-events: none;
        z-index: 0;
      }

      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background: 
          url('data:image/svg+xml,<svg width="100" height="100" xmlns="http://www.w3.org/2000/svg"><defs><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" result="noise"/></filter></defs><rect width="100" height="100" fill="%230f172a" filter="url(%23noise)" opacity="0.05"/></svg>');
        animation: float 30s ease-in-out infinite;
        pointer-events: none;
        z-index: 0;
      }

      @keyframes gradientShift {
        0%, 100% { transform: translate(0, 0) scale(1); }
        25% { transform: translate(50px, -50px) scale(1.1); }
        50% { transform: translate(-50px, 50px) scale(0.9); }
        75% { transform: translate(30px, 30px) scale(1.05); }
      }

      @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(20px); }
      }

      /* Page Transition Wrapper */
      #page-transition-wrapper {
        position: relative;
        z-index: 10;
        opacity: 0;
        transform: translate3d(0, 40px, 0) scale(0.95) rotateX(10deg);
        filter: blur(20px);
        transition: all 0.7s cubic-bezier(0.23, 1, 0.320, 1);
      }

      #page-transition-wrapper.ready {
        opacity: 1;
        transform: translate3d(0, 0, 0) scale(1) rotateX(0deg);
        filter: blur(0);
      }

      #page-transition-wrapper.exiting {
        opacity: 0;
        transform: translate3d(0, -40px, 0) scale(0.95) rotateX(-10deg);
        filter: blur(20px);
      }

      /* Transition Overlay */
      #transition-overlay {
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0;
        z-index: 9999;
        background: 
          radial-gradient(circle at 15% 20%, rgba(59, 130, 246, 0.5), transparent 25%),
          radial-gradient(circle at 85% 30%, rgba(168, 85, 247, 0.4), transparent 25%),
          radial-gradient(circle at 50% 90%, rgba(34, 197, 94, 0.3), transparent 30%);
        backdrop-filter: blur(40px);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }

      #transition-overlay.active {
        opacity: 1;
      }

      /* ==================== HEADER ==================== */
      header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        height: 80px;
        background: linear-gradient(180deg, rgba(15, 23, 42, 0.95) 0%, rgba(30, 41, 59, 0.7) 100%);
        backdrop-filter: blur(30px) saturate(200%);
        border-bottom: 1px solid rgba(148, 163, 184, 0.15);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5),
                    inset 0 1px 0 rgba(255, 255, 255, 0.1);
        animation: slideDown 0.6s cubic-bezier(0.23, 1, 0.320, 1);
      }

      @keyframes slideDown {
        from {
          transform: translateY(-100%);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }

      header::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.15), transparent 50%),
                    radial-gradient(circle at top left, rgba(168, 85, 247, 0.1), transparent 50%);
        pointer-events: none;
      }

      body {
        padding-top: 80px;
      }

      .header-content {
        position: relative;
        z-index: 10;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2rem;
      }

      /* Logo & Brand */
      .logo-container {
        display: flex;
        align-items: center;
        gap: 16px;
        cursor: pointer;
      }

      .logo-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 16px;
        background: linear-gradient(135deg, #3b82f6 0%, #7c3aed 50%, #1e40af 100%);
        box-shadow: 0 10px 30px rgba(59, 130, 246, 0.4),
                    0 0 0 1px rgba(255, 255, 255, 0.1),
                    inset 0 1px 2px rgba(255, 255, 255, 0.2),
                    inset 0 -2px 5px rgba(0, 0, 0, 0.3);
        position: relative;
        overflow: hidden;
        animation: float 3s ease-in-out infinite;
      }

      @keyframes float {
        0%, 100% { transform: translateY(0px) scale(1); }
        50% { transform: translateY(-8px) scale(1.02); }
      }

      .logo-icon::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(45deg, 
          transparent 30%, 
          rgba(255, 255, 255, 0.2) 50%, 
          transparent 70%);
        animation: shimmer 4s infinite;
      }

      @keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
      }

      .logo-icon:hover {
        transform: translateY(-4px) scale(1.05);
        box-shadow: 0 15px 40px rgba(59, 130, 246, 0.5),
                    0 0 0 1px rgba(255, 255, 255, 0.15),
                    inset 0 1px 2px rgba(255, 255, 255, 0.3),
                    inset 0 -2px 5px rgba(0, 0, 0, 0.3);
      }

      .logo-text {
        font-size: 1.25rem;
        font-weight: 800;
        background: linear-gradient(135deg, #3b82f6 0%, #7c3aed 50%, #06b6d4 100%);
        background-size: 200% 200%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: gradientFlow 8s ease infinite;
        letter-spacing: -0.5px;
      }

      @keyframes gradientFlow {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
      }

      /* Navigation */
      nav {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      nav a {
        position: relative;
        padding: 8px 16px;
        color: rgba(203, 213, 225, 0.8);
        font-weight: 500;
        font-size: 0.95rem;
        overflow: hidden;
        transition: all 0.3s ease;
      }

      nav a::before {
        content: '';
        position: absolute;
        bottom: 0;
        left: -100%;
        width: 100%;
        height: 3px;
        background: linear-gradient(90deg, #3b82f6, #7c3aed, #06b6d4);
        transition: left 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      nav a::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(59, 130, 246, 0.1), transparent 70%);
        opacity: 0;
        transition: opacity 0.3s ease;
      }

      nav a:hover {
        color: #ffffff;
      }

      nav a:hover::before {
        left: 0;
      }

      nav a:hover::after {
        opacity: 1;
      }

      /* Auth Buttons */
      .auth-buttons {
        display: flex;
        align-items: center;
        gap: 12px;
        position: relative;
        z-index: 10;
      }

      /* Button Base */
      .btn {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        overflow: hidden;
        cursor: pointer;
        border: none;
        white-space: nowrap;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      /* Primary Button */
      .btn-primary {
        background: linear-gradient(135deg, #3b82f6 0%, #7c3aed 50%, #06b6d4 100%);
        background-size: 200% 200%;
        color: white;
        box-shadow: 0 15px 35px rgba(59, 130, 246, 0.35),
                    inset 0 1px 2px rgba(255, 255, 255, 0.2),
                    inset 0 -2px 5px rgba(0, 0, 0, 0.2);
        animation: pulse-glow 2s ease-in-out infinite;
      }

      @keyframes pulse-glow {
        0%, 100% { box-shadow: 0 15px 35px rgba(59, 130, 246, 0.35),
                              inset 0 1px 2px rgba(255, 255, 255, 0.2); }
        50% { box-shadow: 0 20px 45px rgba(59, 130, 246, 0.5),
                         inset 0 1px 2px rgba(255, 255, 255, 0.3); }
      }

      .btn-primary::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(45deg, transparent 30%, rgba(255, 255, 255, 0.25) 50%, transparent 70%);
        animation: shine 3s infinite;
        z-index: 1;
      }

      @keyframes shine {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
      }

      .btn-primary:hover {
        transform: translateY(-4px) scale(1.02);
        box-shadow: 0 25px 50px rgba(59, 130, 246, 0.45),
                    inset 0 1px 2px rgba(255, 255, 255, 0.3);
      }

      .btn-primary:active {
        transform: translateY(-1px) scale(0.98);
      }

      .btn-primary span {
        position: relative;
        z-index: 2;
      }

      /* Secondary Button */
      .btn-secondary {
        background: rgba(203, 213, 225, 0.1);
        color: rgba(226, 232, 240, 0.95);
        border: 1.5px solid rgba(148, 163, 184, 0.25);
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
      }

      .btn-secondary::before {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(59, 130, 246, 0.1);
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: 0;
      }

      .btn-secondary:hover {
        background: rgba(59, 130, 246, 0.15);
        border-color: rgba(59, 130, 246, 0.5);
        color: #ffffff;
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(59, 130, 246, 0.2),
                    inset 0 1px 2px rgba(255, 255, 255, 0.1);
      }

      .btn-secondary span {
        position: relative;
        z-index: 2;
      }

      /* User Badge */
      .user-badge {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(168, 85, 247, 0.1) 100%);
        border: 1.5px solid rgba(148, 163, 184, 0.2);
        backdrop-filter: blur(15px);
        animation: slideInDown 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      @keyframes slideInDown {
        from {
          opacity: 0;
          transform: translateY(-20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .user-badge svg {
        filter: drop-shadow(0 0 3px rgba(59, 130, 246, 0.6));
        animation: pulse 2s ease-in-out infinite;
      }

      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
      }

      .user-badge-text {
        display: flex;
        flex-direction: column;
      }

      .user-badge-label {
        font-size: 0.75rem;
        color: rgba(148, 163, 184, 0.7);
        font-weight: 500;
        letter-spacing: 0.5px;
      }

      .user-badge-email {
        font-size: 0.85rem;
        color: #ffffff;
        font-weight: 600;
        letter-spacing: -0.3px;
      }

      /* Main Content */
      main {
        position: relative;
        z-index: 10;
        min-height: calc(100vh - 260px);
      }

      /* Alerts */
      .alert-container {
        position: fixed;
        top: 100px;
        right: 20px;
        max-width: 450px;
        z-index: 100;
        animation: slideInRight 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      @keyframes slideInRight {
        from {
          opacity: 0;
          transform: translateX(100px) scale(0.9) rotateY(45deg);
        }
        to {
          opacity: 1;
          transform: translateX(0) scale(1) rotateY(0deg);
        }
      }

      .alert-box {
        border-radius: 16px;
        padding: 16px 20px;
        backdrop-filter: blur(20px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3),
                    inset 0 1px 1px rgba(255, 255, 255, 0.1);
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .alert-success {
        background: linear-gradient(135deg, rgba(34, 197, 94, 0.2) 0%, rgba(16, 185, 129, 0.1) 100%);
        border: 1px solid rgba(34, 197, 94, 0.4);
      }

      .alert-error {
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.2) 0%, rgba(220, 38, 38, 0.1) 100%);
        border: 1px solid rgba(239, 68, 68, 0.4);
      }

      .alert-icon {
        flex-shrink: 0;
        animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      @keyframes popIn {
        0% { transform: scale(0) rotate(-45deg); opacity: 0; }
        100% { transform: scale(1) rotate(0); opacity: 1; }
      }

      /* Footer */
      footer {
        position: relative;
        z-index: 10;
        background: linear-gradient(180deg, rgba(15, 23, 42, 0.9) 0%, rgba(20, 30, 48, 0.8) 100%);
        border-top: 1px solid rgba(148, 163, 184, 0.1);
        backdrop-filter: blur(20px);
        box-shadow: 0 -25px 50px rgba(0, 0, 0, 0.4),
                    inset 0 1px 0 rgba(255, 255, 255, 0.05);
        animation: slideUp 0.7s cubic-bezier(0.23, 1, 0.320, 1);
      }

      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(50px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      footer::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.1), transparent 50%),
                    radial-gradient(circle at bottom right, rgba(168, 85, 247, 0.1), transparent 50%);
        pointer-events: none;
      }

      /* Social Links */
      footer a {
        color: rgba(148, 163, 184, 0.7);
        transition: all 0.3s ease;
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        text-decoration: none;
      }

      footer a::before {
        content: '';
        position: absolute;
        inset: -4px;
        border-radius: 10px;
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(168, 85, 247, 0.15));
        opacity: 0;
        transition: all 0.3s ease;
        z-index: -1;
      }

      footer a:hover {
        color: #ffffff;
        transform: translateY(-4px) scale(1.1);
      }

      footer a:hover::before {
        opacity: 1;
        box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
      }

      /* Scrollbar */
      ::-webkit-scrollbar {
        width: 12px;
      }

      ::-webkit-scrollbar-track {
        background: rgba(15, 23, 42, 0.5);
      }

      ::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, #3b82f6 0%, #7c3aed 100%);
        border-radius: 6px;
        box-shadow: 0 0 10px rgba(59, 130, 246, 0.3) inset;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(180deg, #1e40af 0%, #6d28d9 100%);
        box-shadow: 0 0 15px rgba(59, 130, 246, 0.4) inset;
      }
    </style>
  </head>

  <body class="min-w-full">
    <!-- Fixed Header Navigation -->
    <header>
      <div class="header-content max-w-full px-4 sm:px-6 lg:px-8">
        
        <!-- Logo & Brand -->
        <div class="flex items-center gap-12 flex-1">
          <div class="logo-container group">
            <%= link_to (logged_in? ? links_path : root_path), class: "flex items-center gap-3", data: { transition: true } do %>
              <div class="logo-icon">
                <span class="text-2xl font-bold text-white relative z-10">⚡</span>
              </div>
              <span class="logo-text hidden sm:inline">FluxLink</span>
            <% end %>
          </div>

          <!-- Navigation (Desktop) -->
          <% unless logged_in? %>
            <nav class="hidden lg:flex items-center">
              <%= link_to "Home", root_path, data: { transition: true } %>
              <%= link_to "Features", features_path, data: { transition: true } %>
              <%= link_to "Pricing", pricing_path, data: { transition: true } %>
              <%= link_to "About", about_path, data: { transition: true } %>
              <%= link_to "Contact", contact_path, data: { transition: true } %>
            </nav>
          <% end %>
        </div>

        <!-- Right Side Actions -->
        <div class="auth-buttons">
          <% if logged_in? %>
            <!-- User Info Badge -->
            <div class="user-badge hidden md:flex">
              <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
              </svg>
              <div class="user-badge-text">
                <span class="user-badge-label">Signed in as</span>
                <span class="user-badge-email"><%= current_user.email %></span>
              </div>
            </div>

            <!-- Dashboard Link -->
            <%= link_to "📊 Dashboard", links_path, class: "btn btn-secondary hidden sm:inline-flex", data: { transition: true } %>

            <!-- Logout -->
            <%= button_to "🚪 Logout", logout_path, method: :delete, class: "btn btn-primary !bg-gradient-to-r !from-red-500 !to-pink-600 !shadow-lg !shadow-red-500/25" %>
          <% else %>
            <!-- Login -->
            <%= link_to "Sign In", login_path, class: "btn btn-secondary", data: { transition: true } %>

            <!-- Sign Up (CTA) -->
            <%= link_to "Get Started", signup_path, class: "btn btn-primary", data: { transition: true } %>
          <% end %>
        </div>
      </div>
    </header>

    <!-- Main Page Wrapper -->
    <div id="page-transition-wrapper" class="w-full mx-auto max-w-full">
      <main class="w-full">
        <!-- Success Alert -->
        <% if notice.present? %>
          <div class="alert-container">
            <div class="alert-box alert-success">
              <svg class="alert-icon w-5 h-5 text-green-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <p class="text-sm font-medium text-green-300"><%= notice %></p>
            </div>
          </div>
        <% end %>

        <!-- Error Alert -->
        <% if alert.present? %>
          <div class="alert-container">
            <div class="alert-box alert-error">
              <svg class="alert-icon w-5 h-5 text-red-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
              <p class="text-sm font-medium text-red-300"><%= alert %></p>
            </div>
          </div>
        <% end %>

        <!-- Page Content -->
        <%= yield %>
      </main>
    </div>

    <!-- Premium Footer -->
    <footer>
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid gap-12 md:grid-cols-4 mb-12">
          
          <!-- Brand Section -->
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 shadow-lg">
                <span class="text-lg font-bold text-white">⚡</span>
              </div>
              <span class="font-bold text-white text-lg">FluxLink</span>
            </div>
            <p class="text-sm text-slate-400 leading-relaxed">Smart URL shortening for modern teams and creators.</p>
            <div class="flex items-center gap-2 pt-2">
              <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
              <span class="text-xs text-slate-500">System Operational</span>
            </div>
          </div>

          <!-- Product Links -->
          <div class="space-y-4">
            <h4 class="font-bold text-white uppercase tracking-wider text-xs">Product</h4>
            <ul class="space-y-3 text-sm">
              <li><%= link_to "Features", features_path, class: "text-slate-400 hover:text-white", data: { transition: true } %></li>
              <li><%= link_to "Pricing", pricing_path, class: "text-slate-400 hover:text-white", data: { transition: true } %></li>
              <li><a href="#" class="text-slate-400 hover:text-white">API Docs</a></li>
              <li><a href="#" class="text-slate-400 hover:text-white">Changelog</a></li>
            </ul>
          </div>

          <!-- Company Links -->
          <div class="space-y-4">
            <h4 class="font-bold text-white uppercase tracking-wider text-xs">Company</h4>
            <ul class="space-y-3 text-sm">
