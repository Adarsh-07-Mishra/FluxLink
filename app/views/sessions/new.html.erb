<div class="relative min-h-screen overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-slate-100">
  
  <!-- Animated background gradients -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 left-1/4 w-80 h-80 bg-indigo-500/30 rounded-full blur-3xl opacity-20 animate-pulse"></div>
    <div class="absolute top-1/3 -right-20 w-96 h-96 bg-sky-500/25 rounded-full blur-3xl opacity-20 animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute -bottom-32 left-1/2 w-80 h-80 bg-cyan-500/20 rounded-full blur-3xl opacity-20 -translate-x-1/2 animate-pulse" style="animation-delay: 4s;"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
    
    <div class="grid gap-8 lg:gap-12 lg:grid-cols-[1.2fr_.8fr]">

      <!-- LEFT SIDE - Info -->
      <div class="space-y-8">

        <!-- Header -->
        <div class="space-y-6">
          <div class="inline-flex">
            <span class="rounded-full bg-gradient-to-r from-indigo-500/20 to-sky-500/20 px-5 py-2 text-xs font-semibold uppercase tracking-widest text-indigo-300 border border-indigo-400/20 backdrop-blur-sm">
              Welcome Back
            </span>
          </div>

          <div class="space-y-4">
            <h1 class="text-5xl lg:text-6xl font-bold tracking-tight text-white leading-tight">
              Access your 
              <span class="bg-gradient-to-r from-indigo-400 via-sky-400 to-cyan-400 bg-clip-text text-transparent">dashboard</span>
            </h1>
            <p class="text-xl text-slate-300 leading-relaxed max-w-xl">
              Sign in to manage your short links, track analytics, and access all your saved URLs in one secure place.
            </p>
          </div>
        </div>

        <!-- Feature Cards -->
        <div class="grid gap-4">
          <% [
            { icon: '🔐', title: 'Secure Access', desc: 'JWT-protected sessions with industry-standard encryption' },
            { icon: '📊', title: 'Your Analytics', desc: 'View real-time click data and performance metrics' },
            { icon: '🔗', title: 'Manage Links', desc: 'Edit, pause, or delete your short links anytime' },
            { icon: '⚡', title: 'Fast & Smooth', desc: 'Lightning-quick load times with zero friction' }
          ].each do |feature| %>
            <div class="group bg-gradient-to-r from-indigo-500/10 to-sky-500/10 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-5 hover:border-indigo-400/50 transition duration-300">
              <div class="flex items-start gap-4">
                <span class="text-2xl flex-shrink-0"><%= feature[:icon] %></span>
                <div>
                  <h3 class="font-semibold text-white"><%= feature[:title] %></h3>
                  <p class="text-sm text-slate-400 mt-1"><%= feature[:desc] %></p>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Security Badge -->
        <div class="bg-gradient-to-br from-slate-800/50 to-slate-900/50 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6">
          <div class="flex items-start gap-4">
            <div class="flex items-center justify-center w-10 h-10 rounded-full bg-green-500/20 border border-green-500/30 flex-shrink-0">
              <svg class="w-6 h-6 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-white mb-1">🔐 Your data is protected</p>
              <p class="text-xs text-slate-400">SSL encrypted • Password hashed • No third-party access</p>
            </div>
          </div>
        </div>

      </div>

      <!-- RIGHT SIDE - Login Form -->
      <div class="bg-gradient-to-br from-slate-800/50 to-slate-900/50 backdrop-blur-xl rounded-3xl border border-slate-700/50 shadow-2xl p-8 md:p-10 lg:sticky lg:top-8 h-fit">
        
        <!-- Form Header -->
        <div class="mb-8 space-y-2">
          <p class="text-xs uppercase tracking-widest text-indigo-400 font-semibold">Sign In</p>
          <h2 class="text-3xl font-bold text-white">Welcome back</h2>
          <p class="text-slate-400 text-sm">Access your account and continue managing links</p>
        </div>

        <!-- Error Messages -->
        <% if flash[:alert].present? %>
          <div class="mb-6 bg-red-500/10 border border-red-500/30 rounded-2xl p-4 backdrop-blur-sm">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
              <div>
                <p class="font-semibold text-red-300"><%= flash[:alert] %></p>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Form -->
        <%= form_with url: login_path, local: true, class: "space-y-5" do |form| %>
          
          <% if params[:original_url].present? %>
            <%= hidden_field_tag :original_url, params[:original_url] %>
          <% end %>

          <!-- Email Field -->
          <div class="space-y-2">
            <%= form.label :email, "Email Address", class: "block text-sm font-semibold text-slate-300" %>
            <div class="relative">
              <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4 text-slate-500">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </span>
              <%= form.email_field :email, 
                  required: true,
                  class: "w-full rounded-2xl border-2 border-slate-600 bg-slate-900/50 px-5 py-3 pl-12 text-white placeholder-slate-500 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/30 transition duration-200",
                  placeholder: "you@example.com" %>
            </div>
          </div>

          <!-- Password Field -->
          <div class="space-y-2">
            <%= form.label :password, "Password", class: "block text-sm font-semibold text-slate-300" %>
            <div class="relative">
              <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4 text-slate-500">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              </span>
              <%= form.password_field :password, 
                  required: true,
                  class: "w-full rounded-2xl border-2 border-slate-600 bg-slate-900/50 px-5 py-3 pl-12 text-white placeholder-slate-500 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/30 transition duration-200",
                  placeholder: "••••••••" %>
            </div>
          </div>

          <!-- Remember Me & Forgot Password -->
          <div class="flex items-center justify-between pt-2">
            <label class="flex items-center gap-2 cursor-pointer group">
              <%= form.check_box :remember_me, { class: "w-5 h-5 rounded border-2 border-slate-600 bg-slate-900/50 text-indigo-500 focus:ring-2 focus:ring-indigo-500/30 cursor-pointer" } %>
              <span class="text-sm text-slate-400 group-hover:text-slate-300 transition">Keep me signed in</span>
            </label>
            <a href="#" class="text-sm text-indigo-400 hover:text-indigo-300 transition font-medium">Forgot password?</a>
          </div>

          <!-- Submit Button -->
          <div class="pt-2">
            <%= form.submit "Sign In", 
                class: "w-full rounded-2xl bg-gradient-to-r from-indigo-600 to-sky-600 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-indigo-500/30 hover:shadow-xl hover:from-indigo-700 hover:to-sky-700 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:ring-offset-2 focus:ring-offset-slate-900 transition duration-300 active:scale-95" %>
          </div>

        <% end %>

        <!-- Divider -->
        <div class="relative my-6">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-slate-600"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-3 bg-gradient-to-b from-slate-800/50 to-slate-900/50 text-slate-400">or</span>
          </div>
        </div>

        <!-- OAuth Option (if implemented) -->
        <button type="button" class="w-full rounded-2xl border-2 border-slate-600 bg-slate-900/50 px-6 py-3 text-base font-semibold text-white hover:border-indigo-500 hover:bg-slate-900 transition duration-200 flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.85 4.05-1.27 1.45-3.257 2.986-6.59 2.986-5.231 0-9.502-4.144-9.502-9.502s4.271-9.502 9.502-9.502c2.92 0 5.603 1.064 7.178 2.989l2.335-2.336C19.268 1.889 16.823 0 12.48 0 5.597 0 .073 5.52.073 12.497s5.524 12.497 12.407 12.497c3.368 0 6.189-1.107 8.302-3.107 2.051-1.898 3.395-4.649 3.576-7.98.04-.526.056-1.189.056-1.963v-.92H12.48z"/>
          </svg>
          Continue with Google
        </button>

        <!-- Sign Up Link -->
        <div class="text-center pt-6 border-t border-slate-600">
          <p class="text-slate-400 text-sm">
            New to Fl
