<div class="relative min-h-screen overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 text-slate-100">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(56,189,248,0.16),_transparent_25%),radial-gradient(circle_at_bottom_right,_rgba(129,140,248,0.12),_transparent_25%)]"></div>
  <div class="absolute left-[-8%] top-20 h-72 w-72 rounded-full bg-indigo-500/20 blur-3xl opacity-80 animate-pulse-slow"></div>
  <div class="absolute right-[-10%] top-28 h-80 w-80 rounded-full bg-sky-500/20 blur-3xl opacity-75 animate-float"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14 lg:py-20">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_.8fr] items-center">

      <section class="space-y-8">
        <div class="space-y-4 max-w-2xl">
          <span class="inline-flex items-center rounded-full border border-indigo-400/20 bg-indigo-500/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.28em] text-indigo-300 backdrop-blur-sm">
            Welcome Back
          </span>
          <h1 class="text-5xl lg:text-6xl font-semibold tracking-tight text-white leading-tight">
            Access your <span class="bg-gradient-to-r from-indigo-400 via-sky-400 to-cyan-400 bg-clip-text text-transparent">FluxLink dashboard</span>
          </h1>
          <p class="text-lg text-slate-400 leading-relaxed">
            Sign in to manage your short links, view analytics, and unlock WiFi QR code tools in a sleek, secure workspace.
          </p>
        </div>

        <div class="grid gap-4">
          <div class="group rounded-3xl border border-slate-700/60 bg-slate-900/70 p-6 shadow-xl shadow-slate-950/20 transition duration-300 hover:-translate-y-1 hover:border-indigo-400/40">
            <div class="flex items-center gap-4">
              <div class="h-12 w-12 rounded-3xl bg-indigo-500/10 text-indigo-300 flex items-center justify-center">🔐</div>
              <div>
                <h3 class="text-lg font-semibold text-white">Secure Access</h3>
                <p class="text-sm text-slate-400">JWT sessions, encrypted cookies, and secure login flows keep your account safe.</p>
              </div>
            </div>
          </div>
          <div class="group rounded-3xl border border-slate-700/60 bg-slate-900/70 p-6 shadow-xl shadow-slate-950/20 transition duration-300 hover:-translate-y-1 hover:border-sky-400/40">
            <div class="flex items-center gap-4">
              <div class="h-12 w-12 rounded-3xl bg-sky-500/10 text-sky-300 flex items-center justify-center">📊</div>
              <div>
                <h3 class="text-lg font-semibold text-white">Your Analytics</h3>
                <p class="text-sm text-slate-400">Track every click, see engagement trends, and optimize your shared links.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-3xl border border-slate-700/60 bg-slate-900/80 p-6 shadow-2xl shadow-slate-950/20">
          <p class="text-sm uppercase tracking-[0.22em] text-slate-500">Pro tip</p>
          <p class="mt-3 text-slate-300">Use the same email and strong password to keep your links secure across every device.</p>
        </div>
      </section>

      <section class="relative overflow-hidden rounded-[2.5rem] border border-slate-700/30 bg-slate-950/85 p-8 shadow-2xl shadow-slate-950/40 backdrop-blur-2xl transition duration-700 ease-out hover:-translate-y-1">
        <div class="absolute inset-0 overflow-hidden">
          <div class="absolute -left-20 -top-24 h-72 w-72 rounded-full bg-cyan-500/15 blur-3xl opacity-90 animate-float-slow"></div>
          <div class="absolute -right-16 top-16 h-72 w-72 rounded-full bg-pink-500/20 blur-3xl opacity-80 animate-pulse-slow"></div>
          <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-slate-950/85 to-transparent"></div>
          <div class="absolute inset-y-0 right-[20%] w-1.5 rounded-full bg-gradient-to-b from-cyan-400/40 to-transparent blur-xl"></div>
        </div>

        <div class="relative z-10 grid gap-8 animate-slide-in-up">
          <div class="space-y-3">
            <span class="inline-flex items-center rounded-full border border-cyan-300/20 bg-cyan-500/10 px-4 py-2 text-xs uppercase tracking-[0.3em] text-cyan-200">Stylish + Secure</span>
            <h2 class="text-4xl font-bold tracking-tight text-white">Sign in with FluxLink energy</h2>
            <p class="max-w-xl text-slate-400">A distinctive login experience with softer glass panels, glowing accents, and motion that feels premium without extra distraction.</p>
          </div>

          <% if flash[:alert].present? %>
            <div class="rounded-3xl border border-red-500/40 bg-red-600/10 p-4 text-sm text-red-100 shadow-sm shadow-red-500/10">
              <p><strong>Oops:</strong> <%= flash[:alert] %></p>
            </div>
          <% end %>

          <%= form_with(url: login_path, local: true) do |form| %>
            <% if params[:original_url].present? %>
              <%= hidden_field_tag :original_url, params[:original_url] %>
            <% end %>

            <div class="space-y-5">
              <div class="rounded-[2rem] border border-slate-700/70 bg-slate-950/90 p-5 shadow-[0_18px_60px_-45px_rgba(15,23,42,0.9)] transition duration-300 hover:border-cyan-400/40">
                <label class="block text-sm font-semibold text-slate-300" for="user_email">Email</label>
                <div class="mt-3 flex items-center gap-3 rounded-3xl border border-slate-800 bg-slate-900/95 px-4 py-3 ring-1 ring-slate-800/50 transition focus-within:border-cyan-400 focus-within:ring-cyan-400/20">
                  <span class="text-cyan-400">@</span>
                  <%= form.email_field :email, required: true, class: "w-full bg-transparent text-white placeholder:text-slate-500 focus:outline-none", placeholder: "you@example.com" %>
                </div>
              </div>

              <div class="rounded-[2rem] border border-slate-700/70 bg-slate-950/90 p-5 shadow-[0_18px_60px_-45px_rgba(15,23,42,0.9)] transition duration-300 hover:border-indigo-400/40">
                <label class="block text-sm font-semibold text-slate-300" for="user_password">Password</label>
                <div class="mt-3 flex items-center gap-3 rounded-3xl border border-slate-800 bg-slate-900/95 px-4 py-3 ring-1 ring-slate-800/50 transition focus-within:border-indigo-400 focus-within:ring-indigo-400/20">
                  <span class="text-indigo-400">●●●</span>
                  <%= form.password_field :password, required: true, class: "w-full bg-transparent text-white placeholder:text-slate-500 focus:outline-none", placeholder: "Enter your password" %>
                </div>
              </div>
            </div>

            <div class="space-y-4">
              <div class="rounded-[1.75rem] border border-slate-700/70 bg-slate-950/90 p-4 shadow-[0_18px_60px_-45px_rgba(15,23,42,0.9)] transition duration-300 hover:border-cyan-400/40">
                <label class="group flex items-center justify-between gap-4 rounded-[1.5rem] bg-slate-900/95 p-4 text-sm text-slate-200 transition duration-300 hover:bg-slate-900">
                  <span class="space-y-1">
                    <span class="block font-semibold text-slate-100">Keep me signed in</span>
                    <span class="block text-xs text-slate-400">Stay logged in on this device for faster access.</span>
                  </span>
                  <span class="relative inline-flex h-10 w-16 items-center rounded-full bg-slate-800 p-1 transition duration-300 peer-focus-within:ring-2 peer-focus-within:ring-cyan-400/50">
                    <%= form.check_box :remember_me, class: "peer sr-only" %>
                    <span class="absolute left-1 top-1 h-8 w-8 rounded-full bg-slate-950 shadow-lg transition duration-300 peer-checked:translate-x-6 peer-checked:bg-cyan-400"></span>
                  </span>
                </label>
              </div>

              <div class="flex items-center justify-between text-sm text-slate-400">
                <div></div>
                <a href="#" class="font-semibold text-cyan-300 hover:text-white transition">Forgot password?</a>
              </div>
            </div>

            <div class="grid gap-4">
              <%= form.submit "Sign In", class: "w-full rounded-3xl bg-gradient-to-r from-cyan-500 via-violet-500 to-fuchsia-500 px-5 py-4 text-base font-semibold text-white shadow-[0_20px_70px_-30px_rgba(125,211,252,0.85)] transition duration-300 hover:scale-[1.01] hover:shadow-[0_24px_90px_-32px_rgba(125,211,252,0.9)]" %>
              <a href="#" class="inline-flex w-full items-center justify-center rounded-3xl border border-slate-700 bg-slate-950/90 px-5 py-4 text-sm font-semibold text-slate-100 transition duration-300 hover:border-cyan-400 hover:text-white hover:bg-slate-900/95">
                <svg class="mr-2 h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.85 4.05-1.27 1.45-3.257 2.986-6.59 2.986-5.231 0-9.502-4.144-9.502-9.502s4.271 9.502 9.502 9.502c2.92 0 5.603 1.064 7.178 2.989l2.335-2.336C19.268 1.889 16.823 0 12.48 0 5.597 0 .073 5.52.073 12.497s5.524 12.497 12.407 12.497c3.368 0 6.189-1.107 8.302-3.107 2.051-1.898 3.395-4.649 3.576-7.98.04-.526.056-1.189.056-1.963v-.92H12.48z"/></svg>
                Continue with Google
              </a>
            </div>

            <div class="pt-4 text-center text-sm text-slate-400">
              New to FluxLink? <%= link_to "Sign up", signup_path, class: "text-cyan-300 hover:text-white font-semibold" %>
            </div>
          <% end %>
        </div>
      </section>
    </div>
  </div>
</div>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-16px); }
  }
  .animate-float {
    animation: float 9s ease-in-out infinite;
  }
  @keyframes float-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-24px); }
  }
  .animate-float-slow {
    animation: float-slow 11s ease-in-out infinite;
  }
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 0.6; }
  }
  .animate-pulse-slow {
    animation: pulse-slow 8s ease-in-out infinite;
  }
  @keyframes slide-in-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-slide-in-up {
    animation: slide-in-up 0.7s ease-out forwards;
  }
</style>
