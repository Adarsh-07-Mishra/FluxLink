<div class="relative min-h-screen overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-slate-100">
  
  <!-- Animated background gradients -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-500/30 rounded-full blur-3xl opacity-20 animate-pulse"></div>
    <div class="absolute top-1/3 right-0 w-80 h-80 bg-purple-500/20 rounded-full blur-3xl opacity-15 animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute bottom-0 left-1/2 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl opacity-15 animate-pulse" style="animation-delay: 4s;"></div>
  </div>

  <main class="relative mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">

    <!-- ================= HERO SECTION ================= -->
    <section class="mb-24 space-y-12">
      <div class="grid gap-12 lg:grid-cols-[1.3fr_0.7fr] lg:items-center">
        
        <!-- Left Content -->
        <div class="space-y-8">
          <div class="inline-flex">
            <span class="rounded-full bg-gradient-to-r from-blue-500/20 to-purple-500/20 px-5 py-2 text-sm font-semibold uppercase tracking-widest text-blue-300 border border-blue-400/20 backdrop-blur-sm">
              ⚡ Modern URL Shortener
            </span>
          </div>

          <div class="space-y-6">
            <h1 class="text-6xl lg:text-7xl font-bold tracking-tight text-white leading-tight">
              Shorten URLs, 
              <span class="bg-gradient-to-r from-blue-400 via-purple-400 to-cyan-400 bg-clip-text text-transparent">smart & fast</span>
            </h1>
            <p class="text-xl text-slate-300 leading-relaxed max-w-2xl">
              Create powerful short links with password protection, QR codes, and live analytics. Built for creators, teams, and everyday sharing.
            </p>
          </div>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 pt-4">
            <%= link_to "Start Shortening", signup_path, class: "inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-blue-600 to-purple-600 px-8 py-4 text-base font-semibold text-white shadow-xl shadow-blue-500/30 hover:shadow-2xl hover:from-blue-700 hover:to-purple-700 transition duration-300 hover:scale-105" %>
            <a href="#features" class="inline-flex items-center justify-center rounded-xl border-2 border-slate-500/50 bg-slate-800/50 backdrop-blur-sm px-8 py-4 text-base font-semibold text-white hover:border-blue-400 hover:bg-slate-700/50 transition duration-300">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
              Explore Features
            </a>
          </div>

          <!-- Quick Stats -->
          <div class="grid grid-cols-3 gap-4 pt-8">
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:border-blue-400/30 transition">
              <p class="text-3xl font-bold text-blue-400">0.5s</p>
              <p class="text-xs uppercase tracking-widest text-slate-400 mt-2">Link Creation</p>
            </div>
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:border-purple-400/30 transition">
              <p class="text-3xl font-bold text-purple-400">∞</p>
              <p class="text-xs uppercase tracking-widest text-slate-400 mt-2">Short Links</p>
            </div>
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:border-cyan-400/30 transition">
              <p class="text-3xl font-bold text-cyan-400">🔒</p>
              <p class="text-xs uppercase tracking-widest text-slate-400 mt-2">Secured</p>
            </div>
          </div>
        </div>

        <!-- Right - Quick Create Form -->
        <div class="rounded-3xl bg-gradient-to-br from-slate-800/50 to-slate-900/50 backdrop-blur-xl border border-slate-700/50 p-8 shadow-2xl lg:sticky lg:top-8">
          <div class="mb-8 space-y-2">
            <div class="flex items-center justify-between">
              <h3 class="text-2xl font-bold text-white">Try it now</h3>
              <span class="px-3 py-1 rounded-full bg-gradient-to-r from-blue-500/20 to-purple-500/20 text-xs font-semibold text-blue-300 border border-blue-400/20">LIVE</span>
            </div>
            <p class="text-slate-400">Create your first short link instantly</p>
          </div>

          <%= form_with url: shorten_path, method: :post, local: true, class: "space-y-5" do |form| %>
            
            <div class="space-y-2">
              <label class="block text-sm font-semibold text-slate-300">Destination URL</label>
              <%= form.url_field :original_url,
                  value: @original_url,
                  id: "original_url",
                  class: "w-full rounded-2xl border-2 border-slate-600 bg-slate-900/50 px-5 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30 transition duration-200",
                  placeholder: "https://example.com/your-long-url" %>
            </div>

            <div class="grid gap-3">
              <%= form.submit "Shorten URL", class: "w-full rounded-2xl bg-gradient-to-r from-blue-600 to-purple-600 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-blue-500/30 hover:shadow-xl hover:from-blue-700 hover:to-purple-700 transition duration-300 active:scale-95" %>
            </div>

            <p class="text-xs text-slate-500 text-center">
              Sign up after shortening to save and manage your links
            </p>

          <% end %>

          <!-- Info Box -->
          <div class="mt-6 bg-blue-500/10 border border-blue-500/20 rounded-2xl p-4">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-blue-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 5v8a2 2 0 01-2 2h-5l-5 4v-4H4a2 2 0 01-2-2V5a2 2 0 012-2h12a2 2 0 012 2zm-11-1a1 1 0 11-2 0 1 1 0 012 0zM8 7a1 1 0 100-2 1 1 0 000 2zm5-1a1 1 0 11-2 0 1 1 0 012 0z" clip-rule="evenodd" />
              </svg>
              <p class="text-sm text-blue-300">Your URL is saved during signup, so you won't lose progress</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ================= FEATURES SECTION ================= -->
    <section id="features" class="mb-24">
      <div class="text-center space-y-4 mb-12">
        <p class="text-sm uppercase tracking-widest text-blue-400 font-semibold">Powerful Features</p>
        <h2 class="text-4xl lg:text-5xl font-bold text-white">Everything you need to manage links</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% [
          { icon: '⚡', title: 'Instant Creation', description: 'Create short links in milliseconds with auto-generated codes or custom aliases' },
          { icon: '🔒', title: 'Password Protected', description: 'Lock links behind passwords for private sharing and controlled access' },
          { icon: '📱', title: 'QR Codes', description: 'Generate scannable QR codes for every link automatically' },
          { icon: '📊', title: 'Live Analytics', description: 'Track clicks, see trends, and monitor link performance in real-time' },
          { icon: '🎯', title: 'Custom Codes', description: 'Create memorable short codes that match your brand' },
          { icon: '⏰', title: 'Link Expiration', description: 'Set expiry dates for temporary links and auto-extending links' }
        ].each do |feature| %>
          <div class="group bg-gradient-to-br from-slate-800/30 to-slate-900/30 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-8 hover:border-blue-500/50 hover:from-slate-800/50 hover:to-slate-900/50 transition duration-300">
            <div class="text-4xl mb-4"><%= feature[:icon] %></div>
            <h3 class="text-xl font-bold text-white mb-3"><%= feature[:title] %></h3>
            <p class="text-slate-400 leading-relaxed"><%= feature[:description] %></p>
          </div>
        <% end %>
      </div>
    </section>

    <!-- ================= WORKFLOW SECTION ================= -->
    <section class="mb-24">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        
        <!-- Left - Steps -->
        <div class="space-y-8">
          <div class="space-y-4">
            <p class="text-sm uppercase tracking-widest text-blue-400 font-semibold">How it works</p>
            <h2 class="text-4xl font-bold text-white">Three simple steps</h2>
            <p class="text-slate-400 text-lg">From paste to share in seconds</p>
          </div>

          <div class="space-y-4">
            <% [
              { num: '01', title: 'Paste Your URL', desc: 'Enter your long URL in the form and we\'ll generate a short code instantly' },
              { num: '02', title: 'Customize (Optional)', desc: 'Add password protection, set expiration, or generate a QR code' },
              { num: '03', title: 'Share & Track', desc: 'Copy your short link and monitor clicks from your dashboard' }
            ].each do |step| %>
              <div class="group bg-gradient-to-r from-blue-500/10 to-purple-500/10 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 hover:border-blue-400/50 transition duration-300">
                <div class="flex items-start gap-4">
                  <div class="flex items-center justify-center w-12 h-12 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 text-white font-bold flex-shrink-0 text-lg">
                    <%= step[:num] %>
                  </div>
                  <div class="flex-1">
                    <h3 class="text-lg font-semibold text-white mb-2"><%= step[:title] %></h3>
                    <p class="text-slate-400"><%= step[:desc] %></p>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Right - Preview -->
        <div class="rounded-3xl bg-gradient-to-br from-slate-800/50 to-slate-900/50 backdrop-blur-xl border border-slate-700/50 p-8 shadow-2xl">
          <div class="space-y-6">
            <div class="flex items-center justify-between">
              <span class="text-sm uppercase tracking-widest text-slate-400 font-semibold">Preview</span>
              <span class="px-3 py-1 rounded-full bg-slate-700/50 text-xs font-semibold text-slate-300">Dashboard</span>
            </div>

            <!-- Mock Dashboard -->
            <div class="space-y-4">
              <div class="bg-slate-900/70 rounded-2xl p-4 border border-slate-600/30">
                <p class="text-xs uppercase tracking-widest text-slate-500 mb-3">Your Short Link</p>
                <p class="text-lg font-mono font-bold text-blue-400 break-all">https://short.ly/abc123</p>
              </div>

              <div class="bg-slate-900/70 rounded-2xl p-4 border border-slate-600/30">
                <p class="text-xs uppercase tracking-widest text-slate-500 mb-3">Total Clicks</p>
                <p class="text-3xl font-bold text-green-400">1,234</p>
              </div>

              <div class="bg-slate-900/70 rounded-2xl p-4 border border-slate-600/30">
                <p class="text-xs uppercase tracking-widest text-slate-500 mb-3">QR Code</p>
                <div class="flex items-center justify-center bg-slate-950 rounded-xl p-4 h-32">
                  <div class="w-24 h-24 bg-gradient-to-br from-blue-400 to-purple-400 rounded-lg opacity-30"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ================= STATS SECTION ================= -->
    <section class="mb-24 bg-gradient-to-r from-blue-500/10 to-purple-500/10 backdrop-blur-sm border border-slate-700/50 rounded-3xl p-12">
      <div class="grid gap-8 md:grid-cols-3 text-center">
        <% [
          { value: '128K+', label: 'Short Links Created' },
          { value: '23K+', label: 'Protected Links' },
          { value: '41K+', label: 'QR Codes Generated' }
        ].each do |stat| %>
          <div class="space-y-2">
            <p class="text-5xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent"><%= stat[:value] %></p>
            <p class="text-slate-400 uppercase tracking-widest text-sm"><%= stat[:label] %></p>
          </div>
        <% end %>
      </div>
    </section>

    <!-- ================= TESTIMONIALS SECTION ================= -->
    <section class="mb-24">
      <div class="text-center space-y-4 mb-12">
        <p class="text-sm uppercase tracking-widest text-blue-400 font-semibold">Testimonials</p>
        <h2 class="text-4xl lg:text-5xl font-bold text-white">Trusted by creators & teams</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <% [
          { quote: 'Best link shortener I\'ve used. The QR codes are a game-changer.', author: 'Maya Chen', role: 'Product Manager' },
          { quote: 'Love the password protection feature for sharing private content.', author: 'Jordan Smith', role: 'Freelancer' },
          { quote: 'Fast, intuitive, and the analytics are exactly what I need.', author: 'Sam Patel', role: 'Marketing Lead' }
        ].each do |testimonial| %>
          <div class="bg-gradient-to-br from-slate-800/30 to-slate-900/30 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-8 hover:border-blue-500/50 transition duration-300">
            <div class="flex items-center gap-1 mb-4">
              <% 5.times do %>
                <span class="text-yellow-400">★</span>
              <% end %>
            </div>
            <p class="text-slate-300 leading-relaxed mb-6">"<%= testimonial[:quote] %>"</p>
            <div>
              <p class="text-white font-semibold"><%= testimonial[:author] %></p>
              <p class="text-slate-400 text-sm"><%= testimonial[:role] %></p>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <!-- ================= FAQ SECTION ================= -->
    <section class="mb-24">
      <div class="grid gap-12 lg:grid-cols-2">
        
        <div class="space-y-6">
          <div class="space-y-4">
            <p class="text-sm uppercase tracking-widest text-blue-400 font-semibold">FAQ</p>
            <h2 class="text-4xl font-bold text-white">Questions answered</h2>
          </div>
          <p class="text-slate-400 text-lg">Everything you need to know about creating and managing short links</p>
        </div>

        <div class="space-y-4">
          <% [
            { q: 'Is my URL saved during signup?', a: 'Yes! Your entered URL is preserved during the signup flow so you won\'t lose progress.' },
            { q: 'Can I password protect any link?', a: 'Absolutely. Every link can be locked behind a password for private sharing.' },
            { q: 'Are analytics available?', a: 'Yes. Real-time click counts and trends are visible on your dashboard.' },
            { q: 'Can I customize the short code?', a: 'Yes. You can create memorable custom short codes for your links.' }
          ].each do |item| %>
            <div class="bg-gradient-to-br from-slate-800/30 to-slate-900/30 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 hover:border-blue-500/50 transition duration-300">
              <h4 class="font-semibold text-white mb-3"><%= item[:q] %></h4>
              <p class="text-slate-400 text-sm"><%= item[:a] %></p>
            </div>
          <% end %>
        </div>

      </div>
    </section>

    <!-- ================= CTA SECTION ================= -->
    <section class="bg-gradient-to-r from-blue-600/20 via-purple-600/20 to-cyan-600/20 backdrop-blur-sm border border-slate-700/50 rounded-3xl p-12 text-center">
      <div class="space-y-6">
        <h2 class="text-4xl lg:text-5xl font-bold text-white">Ready to shorten?</h2>
        <p class="text-slate-300 text-lg max-w-2xl mx-auto">Create your first short link today and experience fast, modern link shortening with all the features you need.</p>
        
        <div class="flex flex-col sm:flex-row gap-4 items-center justify-center pt-4">
          <%= link_to "Get Started Now", signup_path, class: "inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-blue-600 to-purple-600 px-8 py-4 text-base font-semibold text-white shadow-xl shadow-blue-500/30 hover:shadow-2xl hover:from-blue-700 hover:to-purple-700 transition duration-300 hover:scale-105" %>
          <%= link_to "View Dashboard", links_path, class: "inline-flex items-center justify-center rounded-xl border-2 border-slate-500/50 bg-slate-800/50 backdrop-blur-sm px-8 py-4 text-base font-semibold text-white hover:border-blue-400 hover:bg-slate-700/50 transition duration-300" %>
        </div>
      </div>
    </section>

    <!-- ================= FOOTER ================= -->
    <footer class="mt-20 border-t border-slate-800 pt-12 text-center">
      <p class="text-slate-400 text-sm">
        Built with ❤️ for modern link sharing. Create your first short URL in seconds.
      </p>
      <p class="text-slate-500 text-xs mt-4">© 2024 FluxLink. All rights reserved.</p>
    </footer>

  </main>

</div>

<!-- CSS Animations -->
<style>
  @keyframes pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }
  
  .animate-pulse {
    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>