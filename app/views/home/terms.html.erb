          <%= link_to "About", about_path, class: "text-slate-300 hover:text-white transition" %>
          <%= link_to "Contact", contact_path, class: "text-slate-300 hover:text-white transition" %>
          <% if logged_in? %>
            <%= link_to "Dashboard", links_path, class: "text-slate-300 hover:text-white transition" %>
            <%= button_to "Logout", logout_path, method: :delete, class: "text-slate-300 hover:text-white transition" %>
          <% else %>
            <%= link_to "Login", login_path, class: "text-slate-300 hover:text-white transition" %>
