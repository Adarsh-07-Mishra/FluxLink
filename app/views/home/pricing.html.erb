<div class="relative min-h-screen overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-slate-100">
  
  <!-- Animated background gradients -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 left-1/4 w-80 h-80 bg-green-500/30 rounded-full blur-3xl opacity-20 animate-pulse"></div>
    <div class="absolute top-1/3 -right-20 w-96 h-96 bg-blue-500/25 rounded-full blur-3xl opacity-20 animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute -bottom-32 left-1/2 w-80 h-80 bg-cyan-500/20 rounded-full blur-3xl opacity-20 -translate-x-1/2 animate-pulse" style="animation-delay: 4s;"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">

    <!-- ================= HEADER SECTION ================= -->
    <section class="mb-20 text-center">
      <div class="space-y-6 max-w-3xl mx-auto">
        <div class="inline-flex justify-center">
          <span class="rounded-full bg-gradient-to-r from-green-500/20 to-blue-500/20 px-5 py-2 text-xs font-semibold uppercase tracking-widest text-green-300 border border-green-400/20 backdrop-blur-sm">
            💰 Transparent Pricing
          </span>
        </div>

        <div class="space-y-4">
          <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white leading-tight">
            Simple, honest 
            <span class="bg-gradient-to-r from-green-400 via-blue-400 to-cyan-400 bg-clip-text text-transparent">pricing</span>
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed max-w-2xl mx-auto">
            Start free. No credit card required. Upgrade anytime when you're ready to unlock premium features.
          </p>
        </div>

        <!-- Toggle Button (for future use) -->
        <div class="flex items-center justify-center gap-4 pt-4">
          <span class="text-sm font-medium text-slate-300">Monthly</span>
          <button class="relative inline-flex items-center h-8 w-14 rounded-full bg-slate-700 cursor-not-allowed opacity-50">
            <span class="inline-block h-6 w-6 transform rounded-full bg-white transition"></span>
          </button>
          <span class="text-sm font-medium text-slate-400">Yearly (Coming Soon)</span>
        </div>
      </div>
    </section>

    <!-- ================= PRICING CARDS ================= -->
    <section class="mb-24">
      <div class="grid gap-8 lg:grid-cols-3 max-w-6xl mx-auto">
        
        <!-- Free Plan -->
        <div class="relative group">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-green-500 to-blue-500 rounded-3xl blur opacity-20 group-hover:opacity-30 transition duration-300"></div>
          <div class="relative bg-gradient-to-br from-slate-800/50 to-slate-900/50 backdrop-blur-xl border border-slate-700/50 rounded-3xl p-10 shadow-2xl hover:shadow-3xl transition duration-300">
            
            <!-- Plan Header -->
            <div class="space-y-4 mb-8">
              <div class="flex items-start justify-between">
                <div>
                  <p class="text-xs uppercase tracking-widest font-semibold text-green-400 mb-2">Most Popular</p>
                  <h3 class="text-3xl font-bold text-white">Starter</h3>
                </div>
                <div class="px-3 py-1 rounded-full bg-green-500/20 border border-green-400/30 text-xs font-semibold text-green-300">
                  FREE
                </div>
              </div>
              <p class="text-slate-400">Perfect for getting started. Forever free, always generous.</p>
            </div>

            <!-- Price -->
            <div class="mb-8 pb-8 border-b border-slate-700">
              <p class="text-4xl font-bold text-white">
                $0<span class="text-lg text-slate-400 font-normal">/month</span>
              </p>
              <p class="text-sm text-slate-400 mt-2">No credit card required</p>
            </div>

            <!-- Features List -->
            <div class="space-y-4 mb-8">
              <% [
                { feature: 'Unlimited short links', included: true },
                { feature: 'Basic analytics', included: true },
                { feature: 'Password protection', included: true },
                { feature: 'QR code generation', included: true },
                { feature: 'Custom short codes', included: false },
                { feature: 'Advanced analytics', included: false },
                { feature: 'Team access', included: false }
              ].each do |item| %>
                <div class="flex items-center gap-3">
                  <% if item[:included] %>
                    <svg class="w-5 h-5 text-green-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-slate-300"><%= item[:feature] %></span>
                  <% else %>
                    <svg class="w-5 h-5 text-slate-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-slate-500"><%= item[:feature] %></span>
                  <% end %>
                </div>
              <% end %>
            </div>

            <!-- CTA Button -->
            <div class="space-y-3">
              <%= link_to "Get Started Free", signup_path, class: "w-full inline-flex items-center justify-center rounded-2xl bg-gradient-to-r from-green-600 to-blue-600 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-green-500/30 hover:shadow-xl hover:from-green-700 hover:to-blue-700 transition duration-300 active:scale-95" %>
              <p class="text-xs text-slate-500 text-center">No card required • Upgrade anytime</p>
            </div>
          </div>
        </div>

        <!-- Pro Plan (Coming Soon) -->
        <div class="relative group opacity-60 cursor-not-allowed">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-purple-500 to-pink-500 rounded-3xl blur opacity-10 group-hover:opacity-20 transition duration-300"></div>
          <div class="relative bg-gradient-to-br from-slate-800/50 to-slate-900/50 backdrop-blur-xl border border-slate-700/50 rounded-3xl p-10 shadow-2xl">
            
            <!-- Coming Soon Badge -->
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="inline-block px-4 py-2 rounded-full bg-gradient-to-r from-purple-600 to-pink-600 text-xs font-semibold text-white shadow-lg">
                🚀 Coming Soon
              </span>
            </div>

            <!-- Plan Header -->
            <div class="space-y-4 mb-8 pt-4">
              <div>
                <p class="text-xs uppercase tracking-widest font-semibold text-purple-400 mb-2">For Creators</p>
                <h3 class="text-3xl font-bold text-white">Pro</h3>
              </div>
              <p class="text-slate-400">Everything in Starter, plus advanced tools for power users.</p>
            </div>

            <!-- Price -->
            <div class="mb-8 pb-8 border-b border-slate-700">
              <p class="text-4xl font-bold text-white">
                $9<span class="text-lg text-slate-400 font-normal">/month</span>
              </p>
              <p class="text-sm text-slate-400 mt-2">Billed monthly</p>
            </div>

            <!-- Features List -->
            <div class="space-y-4 mb-8">
              <% [
                { feature: 'Unlimited short links', included: true },
                { feature: 'Basic analytics', included: true },
                { feature: 'Password protection', included: true },
                { feature: 'QR code generation', included: true },
                { feature: 'Custom short codes', included: true },
                { feature: 'Advanced analytics', included: true },
                { feature: 'Team access', included: false }
              ].each do |item| %>
                <div class="flex items-center gap-3">
                  <% if item[:included] %>
                    <svg class="w-5 h-5 text-purple-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-slate-300"><%= item[:feature] %></span>
                  <% else %>
                    <svg class="w-5 h-5 text-slate-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-slate-500"><%= item[:feature] %></span>
                  <% end %>
                </div>
              <% end %>
            </div>

            <!-- Disabled Button -->
            <div class="space-y-3">
              <button disabled class="w-full inline-flex items-center justify-center rounded-2xl bg-slate-700 px-6 py-3 text-base font-semibold text-slate-400 cursor-not-allowed opacity-50">
                Coming Soon
              </button>
              <p class="text-xs text-slate-500 text-center">Available in Q2 2024</p>
            </div>
          </div>
        </div>

        <!-- Business Plan (Coming Soon) -->
        <div class="relative group opacity-60 cursor-not-allowed">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-orange-500 to-red-500 rounded-3xl blur opacity-10 group-hover:opacity-20 transition duration-300"></div>
          <div class="relative bg-gradient-to-br from-slate-800/50 to-slate-900/50 backdrop-blur-xl border border-slate-700/50 rounded-3xl p-10 shadow-2xl">
            
            <!-- Coming Soon Badge -->
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="inline-block px-4 py-2 rounded-full bg-gradient-to-r from-orange-600 to-red-600 text-xs font-semibold text-white shadow-lg">
                🚀 Coming Soon
              </span>
            </div>

            <!-- Plan Header -->
            <div class="space-y-4 mb-8 pt-4">
              <div>
                <p class="text-xs uppercase tracking-widest font-semibold text-orange-400 mb-2">For Teams</p>
                <h3 class="text-3xl font-bold text-white">Business</h3>
              </div>
              <p class="text-slate-400">Everything in Pro, plus team collaboration and advanced features.</p>
            </div>

            <!-- Price -->
            <div class="mb-8 pb-8 border-b border-slate-700">
              <p class="text-4xl font-bold text-white">
                $29<span class="text-lg text-slate-400 font-normal">/month</span>
              </p>
              <p class="text-sm text-slate-400 mt-2">Billed monthly</p>
            </div>

            <!-- Features List -->
            <div class="space-y-4 mb-8">
              <% [
                { feature: 'Unlimited short links', included: true },
                { feature: 'Basic analytics', included: true },
                { feature: 'Password protection', included: true },
                { feature: 'QR code generation', included: true },
                { feature: 'Custom short codes', included: true },
                { feature: 'Advanced analytics', included: true },
                { feature: 'Team access', included: true }
              ].each do |item| %>
                <div class="flex items-center gap-3">
                  <% if item[:included] %>
                    <svg class="w-5 h-5 text-orange-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-slate-300"><%= item[:feature] %></span>
                  <% else %>
                    <svg class="w-5 h-5 text-slate-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-slate-500"><%= item[:feature] %></span>
                  <% end %>
                </div>
              <% end %>
            </div>

            <!-- Disabled Button -->
            <div class="space-y-3">
              <button disabled class="w-full inline-flex items-center justify-center rounded-2xl bg-slate-700 px-6 py-3 text-base font-semibold text-slate-400 cursor-not-allowed opacity-50">
                Coming Soon
              </button>
              <p class="text-xs text-slate-500 text-center">Available in Q2 2024</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ================= FAQ SECTION ================= -->
    <section class="mb-24">
      <div class="max-w-3xl mx-auto">
        <div class="text-center space-y-4 mb-12">
          <p class="text-sm uppercase tracking-widest text-blue-400 font-semibold">Questions?</p>
          <h2 class="text-4xl font-bold text-white">Frequently asked</h2>
        </div>

        <div class="space-y-4">
          <% [
            { q: 'Can I upgrade or downgrade anytime?', a: 'Yes! You can change your plan at any time. Changes take effect immediately.' },
            { q: 'Is there a free trial for Pro or Business?', a: 'The Starter plan is completely free forever. No trial needed—experience all free features today.' },
            { q: 'What happens if I exceed my plan limits?', a: 'We\'ll notify you before any limits are reached. You can upgrade to a higher plan or contact support.' },
            { q: 'Do you offer discounts for annual billing?', a: 'Annual billing discounts will be available when Pro and Business plans launch in Q2 2024.' },
            { q: 'What payment methods do you accept?', a: 'We accept all major credit cards, PayPal, and bank transfers for annual plans.' }
          ].each do |item| %>
            <div class="bg-gradient-to-br from-slate-800/40 to-slate-900/40 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 hover:border-blue-400/50 transition duration-300">
              <h4 class="font-semibold text-white mb-3"><%= item[:q] %></h4>
              <p class="text-slate-400 text-sm leading-relaxed"><%= item[:a] %></p>
            </div>
          <% end %>
        </div>
      </div>
    </section>

    <!-- ================= GUARANTEE SECTION ================= -->
    <section class="bg-gradient-to-r from-green-600/20 via-blue-600/20 to-cyan-600/20 backdrop-blur-sm border border-slate-700/50 rounded-3xl p-12 text-center">
      <div class="space-y-6 max-w-2xl mx-auto">
        <div class="space-y-3">
          <p class="text-sm uppercase tracking-widest text-green-400 font-semibold">Our Promise</p>
          <h2 class="text-4xl font-bold text-white">Simple. Transparent. Fair.</h2>
          <p class="text-lg text-slate-300">
            No hidden fees. No surprise charges. No complex contracts. Pay for what you use, and cancel anytime.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-3 pt-6">
          <div class="space-y-2">
            <div class="text-3xl">✅</div>
            <p class="font-semibold text-white">No Credit Card</p>
            <p class="text-sm text-slate-400">Start free instantly</p>
          </div>
          <div class="space-y-2">
            <div class="text-3xl">🔄</div>
            <p class="font-semibold text-white">Anytime Cancel</p>
            <p class="text-sm text-slate-400">No penalties</p>
          </div>
          <div class="space-y-2">
            <div class="text-3xl">💰</div>
            <p class="font-semibold text-white">Transparent</p>
            <p class="text-sm text-slate-400">What you see is what you pay</p>
          </div>
        </div>

        <div class="pt-6 border-t border-slate-700">
          <%= link_to "Start Your Free Plan", signup_path, class: "inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-green-600 to-blue-600 px-8 py-4 text-base font-semibold text-white shadow-xl shadow-green-500/30 hover:shadow-2xl hover:from-green-700 hover:to-blue-700 transition duration-300 hover:scale-105" %>
        </div>
      </div>
    </section>

  </div>

</div>

<!-- CSS Animations -->
<style>
  @keyframes pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }
  
  .animate-pulse {
    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>