<div class="relative min-h-screen overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-slate-100">
  
  <!-- Animated background gradients -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 left-1/4 w-80 h-80 bg-blue-500/30 rounded-full blur-3xl opacity-20 animate-pulse"></div>
    <div class="absolute top-1/3 -right-20 w-96 h-96 bg-purple-500/25 rounded-full blur-3xl opacity-20 animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute -bottom-32 left-1/2 w-80 h-80 bg-cyan-500/20 rounded-full blur-3xl opacity-20 -translate-x-1/2 animate-pulse" style="animation-delay: 4s;"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">

    <!-- ================= HERO SECTION ================= -->
    <section class="mb-24">
      <div class="grid gap-12 lg:gap-16 lg:grid-cols-[1.3fr_0.7fr] lg:items-center">
        
        <!-- Left Content -->
        <div class="space-y-8">
          <div class="space-y-6">
            <div class="inline-flex">
              <span class="rounded-full bg-gradient-to-r from-blue-500/20 to-purple-500/20 px-5 py-2 text-xs font-semibold uppercase tracking-widest text-blue-300 border border-blue-400/20 backdrop-blur-sm">
                📖 Our Story
              </span>
            </div>

            <div class="space-y-4">
              <h1 class="text-5xl lg:text-6xl font-bold tracking-tight text-white leading-tight">
                Built for smarter, 
                <span class="bg-gradient-to-r from-blue-400 via-purple-400 to-cyan-400 bg-clip-text text-transparent">faster sharing</span>
              </h1>
              <p class="text-xl text-slate-300 leading-relaxed max-w-2xl">
                We created FluxLink because managing short links should be simple, fast, and secure. No complexity. No confusion. Just powerful tools that work.
              </p>
            </div>
          </div>

          <!-- Core Values -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4">
            <% [
              { icon: '🚀', label: 'Fast' },
              { icon: '🔒', label: 'Secure' },
              { icon: '✨', label: 'Simple' },
              { icon: '📊', label: 'Powerful' }
            ].each do |value| %>
              <div class="bg-gradient-to-br from-blue-500/10 to-purple-500/10 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-5 hover:border-blue-400/50 transition duration-300">
                <div class="flex items-center gap-3">
                  <span class="text-3xl"><%= value[:icon] %></span>
                  <p class="font-semibold text-white"><%= value[:label] %></p>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Right - Mission Card -->
        <div class="bg-gradient-to-br from-slate-800/50 to-slate-900/50 backdrop-blur-xl rounded-3xl border border-slate-700/50 shadow-2xl p-10 hover:shadow-3xl transition duration-300">
          <div class="space-y-8">
            <div>
              <p class="text-xs uppercase tracking-widest font-semibold text-blue-400 mb-3">Our Mission</p>
              <h2 class="text-3xl font-bold text-white">Simplify link management</h2>
            </div>

            <p class="text-slate-300 leading-relaxed">
              We believe every link should be easy to create, simple to share, and effortless to manage. Whether you need one-off short URLs or a private network of protected links, FluxLink gives you the tools without the clutter.
            </p>

            <div class="space-y-6 pt-6 border-t border-slate-700">
              <% [
                { icon: '🎯', title: 'Purpose-Built', desc: 'Designed specifically for URL shortening' },
                { icon: '⚡', title: 'Lightning Quick', desc: 'Create and share in seconds' },
                { icon: '🛡️', title: 'Privacy Protected', desc: 'Your data stays yours' }
              ].each do |mission| %>
                <div class="space-y-2">
                  <div class="flex items-center gap-3">
                    <span class="text-2xl"><%= mission[:icon] %></span>
                    <p class="font-semibold text-white"><%= mission[:title] %></p>
                  </div>
                  <p class="text-sm text-slate-400 ml-9"><%= mission[:desc] %></p>
                </div>
              <% end %>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ================= VALUES SECTION ================= -->
    <section class="mb-24">
      <div class="text-center space-y-4 mb-12">
        <p class="text-sm uppercase tracking-widest text-purple-400 font-semibold">Core Values</p>
        <h2 class="text-4xl lg:text-5xl font-bold text-white">What guides us every day</h2>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        <% [
          { 
            icon: '🔒',
            title: 'Privacy First', 
            desc: 'Protect links with passwords. Keep access limited to only the people you choose. Your links, your rules.' 
          },
          { 
            icon: '⚙️',
            title: 'Simple Control', 
            desc: 'Manage your link collection in one beautiful dashboard. See who clicks, update access, revoke anytime.' 
          },
          { 
            icon: '⚡',
            title: 'Instant Results', 
            desc: 'Shorten URLs from the homepage in seconds. No signup required. Customize and share immediately.' 
          }
        ].each do |value| %>
          <div class="group bg-gradient-to-br from-purple-500/10 to-pink-500/10 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-10 hover:border-purple-400/50 hover:from-purple-500/20 hover:to-pink-500/20 transition duration-300">
            <div class="text-5xl mb-4"><%= value[:icon] %></div>
            <h3 class="text-2xl font-bold text-white mb-4"><%= value[:title] %></h3>
            <p class="text-slate-400 leading-relaxed"><%= value[:desc] %></p>
          </div>
        <% end %>
      </div>
    </section>

    <!-- ================= FEATURES HIGHLIGHT ================= -->
    <section class="mb-24">
      <div class="bg-gradient-to-r from-blue-600/20 via-purple-600/20 to-cyan-600/20 backdrop-blur-sm border border-slate-700/50 rounded-3xl p-12 lg:p-16">
        <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
          
          <div class="space-y-8">
            <div class="space-y-4">
              <p class="text-sm uppercase tracking-widest text-blue-400 font-semibold">What We Built</p>
              <h2 class="text-4xl font-bold text-white">A complete URL management platform</h2>
              <p class="text-lg text-slate-300">Everything you need to create, protect, and track your short links in one polished interface.</p>
            </div>

            <div class="space-y-4">
              <% [
                { title: 'Instant Creation', desc: 'Paste a URL and get a short link in milliseconds' },
                { title: 'Password Protection', desc: 'Lock links behind passwords for private sharing' },
                { title: 'QR Codes', desc: 'Automatically generate scannable codes for every link' },
                { title: 'Live Analytics', desc: 'Track clicks and monitor link performance in real-time' },
                { title: 'Link Management', desc: 'Edit, pause, or delete links from your dashboard' },
                { title: 'Custom Codes', desc: 'Create memorable short codes for your brand' }
              ].each do |feature| %>
                <div class="flex items-start gap-4">
                  <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <div>
                    <p class="font-semibold text-white"><%= feature[:title] %></p>
                    <p class="text-sm text-slate-400 mt-1"><%= feature[:desc] %></p>
                  </div>
                </div>
              <% end %>
            </div>
          </div>

          <!-- Visual Element -->
          <div class="rounded-2xl bg-gradient-to-br from-slate-800/50 to-slate-900/50 border border-slate-700/50 p-8 flex items-center justify-center min-h-96">
            <div class="text-center space-y-6">
              <div class="text-6xl">🔗</div>
              <div>
                <p class="text-2xl font-bold text-white mb-2">Simple. Powerful.</p>
                <p class="text-slate-400">Everything you need to master URL shortening</p>
              </div>
              <div class="flex items-center justify-center gap-2 pt-4">
                <span class="w-2 h-2 rounded-full bg-blue-400"></span>
                <span class="w-2 h-2 rounded-full bg-purple-400"></span>
                <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ================= STATS SECTION ================= -->
    <section class="mb-24">
      <div class="bg-gradient-to-br from-slate-800/50 to-slate-900/50 backdrop-blur-xl border border-slate-700/50 rounded-3xl p-12 lg:p-16">
        <div class="grid gap-8 md:grid-cols-4">
          <% [
            { value: '5000+', label: 'Active Users' },
            { value: '128K+', label: 'Short Links' },
            { value: '41K+', label: 'QR Codes' },
            { value: '99.9%', label: 'Uptime' }
          ].each do |stat| %>
            <div class="text-center space-y-3">
              <p class="text-4xl lg:text-5xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
                <%= stat[:value] %>
              </p>
              <p class="text-slate-400 uppercase tracking-widest text-sm font-semibold">
                <%= stat[:label] %>
              </p>
            </div>
          <% end %>
        </div>
      </div>
    </section>

    <!-- ================= TEAM SECTION ================= -->
    <section class="mb-24">
      <div class="space-y-12">
        <div class="text-center space-y-4">
          <p class="text-sm uppercase tracking-widest text-blue-400 font-semibold">Our Team</p>
          <h2 class="text-4xl lg:text-5xl font-bold text-white">Built by creators, for creators</h2>
          <p class="text-lg text-slate-300 max-w-2xl mx-auto">A small team obsessed with building the perfect link management experience.</p>
        </div>

        <div class="grid gap-8 md:grid-cols-3">
          <% [
            { name: 'Adarsh Mishra', role: 'Founder & Developer', emoji: '👨‍💻' },
            { name: 'Coming Soon', role: 'Product Designer', emoji: '🎨' },
            { name: 'Coming Soon', role: 'Community Manager', emoji: '🤝' }
          ].each do |member| %>
            <div class="bg-gradient-to-br from-slate-800/40 to-slate-900/40 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-8 text-center hover:border-blue-400/50 transition duration-300">
              <div class="text-6xl mb-4"><%= member[:emoji] %></div>
              <h3 class="text-xl font-bold text-white"><%= member[:name] %></h3>
              <p class="text-slate-400 text-sm mt-2"><%= member[:role] %></p>
            </div>
          <% end %>
        </div>
      </div>
    </section>

    <!-- ================= CTA SECTION ================= -->
    <section class="bg-gradient-to-r from-blue-600/20 via-purple-600/20 to-cyan-600/20 backdrop-blur-sm border border-slate-700/50 rounded-3xl p-12 text-center">
      <div class="space-y-6 max-w-2xl mx-auto">
        <div class="space-y-3">
          <p class="text-sm uppercase tracking-widest text-blue-400 font-semibold">Ready to join us?</p>
          <h2 class="text-4xl lg:text-5xl font-bold text-white">Start shortening today</h2>
          <p class="text-lg text-slate-300">
            Experience the fastest, simplest URL shortener built for modern teams.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 items-center justify-center pt-4">
          <%= link_to "Get Started Free", signup_path, class: "inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-blue-600 to-purple-600 px-8 py-4 text-base font-semibold text-white shadow-xl shadow-blue-500/30 hover:shadow-2xl hover:from-blue-700 hover:to-purple-700 transition duration-300 hover:scale-105" %>
          <%= link_to "View Features", features_path, class: "inline-flex items-center justify-center rounded-xl border-2 border-slate-500/50 bg-slate-800/50 backdrop-blur-sm px-8 py-4 text-base font-semibold text-white hover:border-blue-400 hover:bg-slate-700/50 transition duration-300" %>
        </div>
      </div>
    </section>

    <!-- ================= FOOTER INFO ================= -->
    <section class="mt-24 pt-12 border-t border-slate-800">
      <div class="grid gap-8 md:grid-cols-3 text-center md:text-left">
        <div class="space-y-3">
          <h4 class="text-sm font-semibold text-blue-400 uppercase tracking-widest">Made with</h4>
          <p class="text-slate-400">Ruby on Rails, Tailwind CSS, and a passion for simplicity.</p>
        </div>
        <div class="space-y-3">
          <h4 class="text-sm font-semibold text-purple-400 uppercase tracking-widest">Open Source</h4>
          <p class="text-slate-400">We believe in transparency. Our code is built on proven technologies.</p>
        </div>
        <div class="space-y-3">
          <h4 class="text-sm font-semibold text-cyan-400 uppercase tracking-widest">Community Driven</h4>
          <p class="text-slate-400">Built by creators, for creators. Your feedback shapes our roadmap.</p>
        </div>
      </div>
    </section>

  </div>

</div>

<!-- CSS Animations -->
<style>
  @keyframes pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }
  
  .animate-pulse {
    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>