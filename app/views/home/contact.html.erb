<div class="min-h-screen bg-slate-950 text-slate-100 px-6 py-16 lg:px-12">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-12 lg:grid-cols-[1fr_0.95fr] lg:items-center">
      <div class="rounded-[32px] bg-white/5 p-10 ring-1 ring-white/10 shadow-[0_25px_80px_rgba(15,23,42,0.25)]">
        <p class="text-sm uppercase tracking-[0.3em] text-sky-400">Contact</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-white">Need help with your links?</h1>
        <p class="mt-6 text-lg leading-8 text-slate-300">Reach out if you have questions about link security, analytics, or the best way to use the app for your workflow.</p>
        <div class="mt-8 space-y-6 text-slate-300">
          <div>
            <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Email</p>
            <p class="mt-2">support@example.com</p>
          </div>
          <div>
            <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Address</p>
            <p class="mt-2">123 Shorten Lane, Web City, Internet</p>
          </div>
          <div>
            <p class="text-sm uppercase tracking-[0.3em] text-slate-400">Need a custom flow?</p>
            <p class="mt-2">Create an account and start building private or public short links in seconds.</p>
          </div>
        </div>
      </div>

      <div class="rounded-[32px] bg-slate-900/90 p-10 ring-1 ring-white/10 shadow-[0_25px_80px_rgba(15,23,42,0.35)] backdrop-blur-xl">
        <h2 class="text-2xl font-semibold text-white">Send us a note</h2>
        <p class="mt-4 text-slate-400">We’ll typically reply within one business day.</p>
        <form class="mt-8 space-y-5" action="mailto:support@example.com" method="post" encType="text/plain">
          <div>
            <label class="text-sm font-medium text-slate-300" for="name">Name</label>
            <input id="name" name="name" type="text" placeholder="Your name" class="mt-3 w-full rounded-3xl border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none transition focus:border-sky-400" />
          </div>
          <div>
            <label class="text-sm font-medium text-slate-300" for="email">Email</label>
            <input id="email" name="email" type="email" placeholder="you@example.com" class="mt-3 w-full rounded-3xl border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none transition focus:border-sky-400" />
          </div>
          <div>
            <label class="text-sm font-medium text-slate-300" for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="How can we help?" class="mt-3 w-full rounded-3xl border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none transition focus:border-sky-400"></textarea>
          </div>
          <button type="submit" class="inline-flex items-center justify-center rounded-full bg-sky-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-sky-400">Send message</button>
        </form>
      </div>
    </div>
  </div>
</div>
