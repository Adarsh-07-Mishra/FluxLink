<div class="relative min-h-screen overflow-hidden bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-slate-100">
  
  <!-- Animated background gradients -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 left-1/4 w-80 h-80 bg-blue-500/30 rounded-full blur-3xl opacity-20 animate-pulse"></div>
    <div class="absolute top-1/3 -right-20 w-96 h-96 bg-purple-500/25 rounded-full blur-3xl opacity-20 animate-pulse" style="animation-delay: 2s;"></div>
    <div class="absolute -bottom-32 left-1/2 w-80 h-80 bg-cyan-500/20 rounded-full blur-3xl opacity-20 -translate-x-1/2 animate-pulse" style="animation-delay: 4s;"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">

    <!-- ================= HEADER SECTION ================= -->
    <section class="mb-20 text-center">
      <div class="space-y-6 max-w-3xl mx-auto">
        <div class="inline-flex justify-center">
          <span class="rounded-full bg-gradient-to-r from-blue-500/20 to-purple-500/20 px-5 py-2 text-xs font-semibold uppercase tracking-widest text-blue-300 border border-blue-400/20 backdrop-blur-sm">
            💬 Get in Touch
          </span>
        </div>

        <div class="space-y-4">
          <h1 class="text-5xl lg:text-6xl font-bold tracking-tight text-white leading-tight">
            We're here to 
            <span class="bg-gradient-to-r from-blue-400 via-purple-400 to-cyan-400 bg-clip-text text-transparent">help</span>
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed max-w-2xl mx-auto">
            Have questions about link security, analytics, or feature requests? Our team is ready to assist you.
          </p>
        </div>
      </div>
    </section>

    <!-- ================= CONTACT GRID ================= -->
    <section class="mb-24">
      <div class="grid gap-8 lg:gap-12 lg:grid-cols-[1.1fr_0.9fr]">

        <!-- LEFT - Contact Information -->
        <div class="space-y-8">
          
          <!-- Main Info Card -->
          <div class="bg-gradient-to-br from-slate-800/50 to-slate-900/50 backdrop-blur-xl rounded-3xl border border-slate-700/50 shadow-2xl p-10 hover:shadow-3xl transition duration-300">
            <div class="space-y-8">
              
              <!-- Email -->
              <div class="space-y-3">
                <div class="flex items-center gap-3 mb-4">
                  <div class="flex items-center justify-center w-12 h-12 rounded-full bg-blue-500/20 border border-blue-400/30">
                    <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <h3 class="text-xl font-bold text-white">Email</h3>
                </div>
                <p class="text-slate-400">support@fluxlink.com</p>
                <p class="text-sm text-slate-500">We reply within 24 hours</p>
              </div>

              <!-- Divider -->
              <div class="h-px bg-gradient-to-r from-slate-700 via-slate-600 to-transparent"></div>

              <!-- Response Time -->
              <div class="space-y-3">
                <div class="flex items-center gap-3 mb-4">
                  <div class="flex items-center justify-center w-12 h-12 rounded-full bg-green-500/20 border border-green-400/30">
                    <svg class="w-6 h-6 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v3.5a1 1 0 102 0V7z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <h3 class="text-xl font-bold text-white">Response Time</h3>
                </div>
                <p class="text-slate-400">Typically within 1 business day</p>
                <p class="text-sm text-slate-500">We're online Mon-Fri, 9am-6pm UTC</p>
              </div>

              <!-- Divider -->
              <div class="h-px bg-gradient-to-r from-slate-700 via-slate-600 to-transparent"></div>

              <!-- Availability -->
              <div class="space-y-3">
                <div class="flex items-center gap-3 mb-4">
                  <div class="flex items-center justify-center w-12 h-12 rounded-full bg-purple-500/20 border border-purple-400/30">
                    <svg class="w-6 h-6 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z" />
                    </svg>
                  </div>
                  <h3 class="text-xl font-bold text-white">24/7 Support</h3>
                </div>
                <p class="text-slate-400">Chat, email, and community support available</p>
                <p class="text-sm text-slate-500">Emergency support for paid plans</p>
              </div>

            </div>
          </div>

          <!-- Quick Links -->
          <div class="grid grid-cols-2 gap-4">
            <% [
              { icon: '📚', title: 'Documentation', desc: 'Read our guides' },
              { icon: '🐛', title: 'Report Bug', desc: 'Found an issue?' },
              { icon: '💡', title: 'Feature Request', desc: 'Suggest an idea' },
              { icon: '🤝', title: 'Partnership', desc: 'Work with us' }
            ].each do |link| %>
              <a href="#" class="bg-gradient-to-br from-slate-800/40 to-slate-900/40 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 hover:border-blue-400/50 transition duration-300 group">
                <div class="text-3xl mb-3"><%= link[:icon] %></div>
                <p class="font-semibold text-white text-sm mb-1"><%= link[:title] %></p>
                <p class="text-xs text-slate-500 group-hover:text-slate-400 transition"><%= link[:desc] %></p>
              </a>
            <% end %>
          </div>

        </div>

        <!-- RIGHT - Contact Form -->
        <div class="bg-gradient-to-br from-slate-800/50 to-slate-900/50 backdrop-blur-xl rounded-3xl border border-slate-700/50 shadow-2xl p-10 lg:sticky lg:top-8 h-fit">
          
          <!-- Form Header -->
          <div class="mb-8 space-y-2">
            <p class="text-xs uppercase tracking-widest text-blue-400 font-semibold">Send a Message</p>
            <h2 class="text-3xl font-bold text-white">Get in touch</h2>
            <p class="text-slate-400 text-sm">Fill out the form and we'll get back to you shortly</p>
          </div>

          <!-- Contact Form -->
          <form class="space-y-5" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
            
            <!-- Name Field -->
            <div class="space-y-2">
              <label class="block text-sm font-semibold text-slate-300" for="name">Full Name</label>
              <input 
                id="name" 
                name="name" 
                type="text" 
                required
                placeholder="John Doe"
                class="w-full rounded-2xl border-2 border-slate-600 bg-slate-900/50 px-5 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30 transition duration-200" />
            </div>

            <!-- Email Field -->
            <div class="space-y-2">
              <label class="block text-sm font-semibold text-slate-300" for="email">Email Address</label>
              <input 
                id="email" 
                name="email" 
                type="email" 
                required
                placeholder="you@example.com"
                class="w-full rounded-2xl border-2 border-slate-600 bg-slate-900/50 px-5 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30 transition duration-200" />
            </div>

            <!-- Subject Field -->
            <div class="space-y-2">
              <label class="block text-sm font-semibold text-slate-300" for="subject">Subject</label>
              <select 
                id="subject" 
                name="subject"
                class="w-full rounded-2xl border-2 border-slate-600 bg-slate-900/50 px-5 py-3 text-white focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30 transition duration-200">
                <option value="" disabled selected>Select a subject</option>
                <option value="support">Support Question</option>
                <option value="bug">Bug Report</option>
                <option value="feature">Feature Request</option>
                <option value="partnership">Partnership</option>
                <option value="other">Other</option>
              </select>
            </div>

            <!-- Message Field -->
            <div class="space-y-2">
              <label class="block text-sm font-semibold text-slate-300" for="message">Message</label>
              <textarea 
                id="message" 
                name="message" 
                rows="6" 
                required
                placeholder="Tell us how we can help..."
                class="w-full rounded-2xl border-2 border-slate-600 bg-slate-900/50 px-5 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30 transition duration-200 resize-none"></textarea>
            </div>

            <!-- Checkbox -->
            <div class="flex items-start gap-3">
              <input 
                type="checkbox" 
                id="agree" 
                name="agree"
                class="w-5 h-5 rounded border-2 border-slate-600 bg-slate-900/50 text-blue-500 focus:ring-2 focus:ring-blue-500/30 cursor-pointer mt-1" />
              <label for="agree" class="text-sm text-slate-400 cursor-pointer">
                I agree to be contacted about my inquiry. We respect your privacy.
              </label>
            </div>

            <!-- Submit Button -->
            <div class="pt-2">
              <button 
                type="submit"
                class="w-full rounded-2xl bg-gradient-to-r from-blue-600 to-purple-600 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-blue-500/30 hover:shadow-xl hover:from-blue-700 hover:to-purple-700 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 focus:ring-offset-slate-900 transition duration-300 active:scale-95">
                Send Message
              </button>
            </div>

            <!-- Help Text -->
            <p class="text-xs text-slate-500 text-center">
              We'll typically respond within 24 hours on business days
            </p>

          </form>

        </div>

      </div>
    </section>

    <!-- ================= FAQ SECTION ================= -->
    <section class="mb-24">
      <div class="max-w-4xl mx-auto">
        <div class="text-center space-y-4 mb-12">
          <p class="text-sm uppercase tracking-widest text-blue-400 font-semibold">Frequently Asked</p>
          <h2 class="text-4xl font-bold text-white">Common questions</h2>
        </div>

        <div class="space-y-4">
          <% [
            { 
              q: 'How quickly will I get a response?', 
              a: 'We typically respond to all inquiries within 24 hours on business days (Mon-Fri). For urgent matters related to paid accounts, we offer priority support.' 
            },
            { 
              q: 'What are your support channels?', 
              a: 'You can reach us via email at support@fluxlink.com, through this contact form, or via our community Slack channel for detailed help.' 
            },
            { 
              q: 'Do you have API documentation?', 
              a: 'Yes! Complete API documentation is available in our docs portal. Visit docs.fluxlink.com to get started.' 
            },
            { 
              q: 'Can I schedule a demo?', 
              a: 'Absolutely. Contact our sales team at sales@fluxlink.com to schedule a personalized walkthrough of FluxLink for your team.' 
            },
            { 
              q: 'What if I found a security issue?', 
              a: 'Please email security@fluxlink.com immediately with details. We take security seriously and will investigate all reports promptly.' 
            }
          ].each do |item| %>
            <div class="bg-gradient-to-br from-slate-800/40 to-slate-900/40 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 hover:border-blue-400/50 transition duration-300">
              <h4 class="font-semibold text-white mb-3"><%= item[:q] %></h4>
              <p class="text-slate-400 text-sm leading-relaxed"><%= item[:a] %></p>
            </div>
          <% end %>
        </div>
      </div>
    </section>

    <!-- ================= SOCIAL SECTION ================= -->
    <section class="bg-gradient-to-r from-blue-600/20 via-purple-600/20 to-cyan-600/20 backdrop-blur-sm border border-slate-700/50 rounded-3xl p-12 text-center">
      <div class="space-y-6 max-w-2xl mx-auto">
        <div class="space-y-3">
          <p class="text-sm uppercase tracking-widest text-blue-400 font-semibold">Connect with us</p>
          <h2 class="text-4xl font-bold text-white">Follow our journey</h2>
          <p class="text-lg text-slate-300">
            Stay updated on new features, tips, and community stories
          </p>
        </div>

        <div class="flex items-center justify-center gap-4 pt-4">
          <% [
            { icon: '𝕏', name: 'Twitter', url: '#' },
            { icon: '💼', name: 'LinkedIn', url: '#' },
            { icon: '🐙', name: 'GitHub', url: '#' },
            { icon: '💬', name: 'Discord', url: '#' }
          ].each do |social| %>
            <a href="<%= social[:url] %>" class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-slate-800/50 border border-slate-700/50 text-slate-400 hover:text-white hover:border-blue-400/50 hover:bg-slate-800 transition duration-300" title="<%= social[:name] %>">
              <span class="text-xl"><%= social[:icon] %></span>
            </a>
          <% end %>
        </div>
      </div>
    </section>

  </div>

</div>

<!-- CSS Animations -->
<style>
  @keyframes pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }
  
  .animate-pulse {
    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>